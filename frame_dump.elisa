# frame_dump.elisa — realtime screen -> framebuffer-as-text, batched "video chunk" edition.
#
# Captures the live screen via the pure-Elisa ScreenCaptureKit bridge (screencap.elisa) at a
# fixed FPS into an in-memory ring of downscaled frames. Every n_seconds the whole batch
# (fps * n_seconds frames) is written to ONE text file and atomically swapped into place
# (tmp + rename), so a polling LLM agent reads a complete "video chunk" and never sees a torn
# or partial batch. Lag for a reader = n_seconds + read time; no frame is ever missed.
#
# Output format (plain text):
#   BATCH <b> frames=<F> <w>x<h> fps=<fps> t0=<ms>
#   FRAME <i> t=<ms>
#   ASCII
#   <h rows of w luminance chars " .:-=+*#%@">
#   ... (repeated for every frame in the batch; the LAST frame also gets:)
#   COLOR
#   <h rows: grayscale cells use the ramp, colored cells use hue letters R O Y G C B M,
#    uppercase = bright, lowercase = dim>
#
# TOKEN BUDGET (the real dial): one ASCII frame is ~w*h chars. Examples per batch:
#   24fps x 2s @ 128 wide (~82 rows)  ->  48 frames * ~10.5KB = ~500KB  (~150K tokens)
#   24fps x 3s @  96 wide (~62 rows)  ->  72 frames * ~6KB    = ~430KB  (~130K tokens)
#   12fps x 5s @  96 wide             ->  60 frames * ~6KB    = ~360KB  (~110K tokens)
#   24fps x 5s @ 256 wide             ->  120 * ~42KB = ~5MB — DOES NOT FIT any context; don't.
#
# USAGE: frame_dump [out_path] [width] [fps] [n_seconds]
#   out_path   batch file to rewrite            (default /tmp/screen_frames.txt)
#   width      downscaled frame width           (default 96; height follows aspect; max 256)
#   fps        capture rate                     (default 24; max 60)
#   n_seconds  batch window in seconds          (default 3; fps*n_seconds capped at 256 frames)

include "./screencap.elisa"

extern fopen(path: u8&, mode: u8&) -> void&?
extern fwrite(ptr: u8&, size: usize, nmemb: usize, stream: void&) -> usize
extern fclose(stream: void&) -> int
extern rename(old: u8&, new: u8&) -> int
extern atoi(s: u8&) -> int
extern printf(fmt: u8&) -> int

global SCREEN_GRAB: array[u32, 24000000] = zeroed
global GRAB_CAP: i32 = 24000000

# Frame ring: up to 256 frames of up to 65536 px each (64MB). Batches are built here, then
# serialized in one pass.
global mutable RING: array[u32, 16777216] = zeroed
global RING_STRIDE: i32 = 65536
global MAX_BATCH_FRAMES: i32 = 256
global mutable FRAME_MS: array[i64, 256] = zeroed
global MAX_OUT_W: i32 = 256

# Per-frame text staging buffer (one frame's text at a time, reused across the batch)
global mutable TXT: array[u8, 2000000] = zeroed
global mutable txt_len: i32 = 0

global HEXD: cstr = "0123456789abcdef"
global RAMP: cstr = " .:-=+*#%@"          # 10-step luminance ramp, dark -> bright

# tmp-file path = out path + ".tmp" (same directory, so rename() is atomic)
global mutable TMP_PATH: array[u8, 1024] = zeroed

def build_tmp_path(path: cstr) -> void:
    i: mutable i32 = 0
    while path[i.usize()] != 0u8 and i < 1000:
        TMP_PATH[i.usize()] <- path[i.usize()]
        i <- i + 1
    ext: cstr = ".tmp"
    j: mutable i32 = 0
    while ext[j.usize()] != 0u8:
        TMP_PATH[(i + j).usize()] <- ext[j.usize()]
        j <- j + 1
    TMP_PATH[(i + j).usize()] <- 0u8

def txt_byte(b: u8) -> void:
    TXT[txt_len.usize()] <- b
    txt_len <- txt_len + 1

def txt_str(s: cstr) -> void:
    i: mutable i32 = 0
    while s[i.usize()] != 0u8:
        txt_byte(s[i.usize()])
        i <- i + 1

def txt_dec(v0: i64) -> void:
    v: mutable i64 = v0
    if v < 0:
        txt_byte(45u8)
        v <- 0 - v
    tmp: mutable array[u8, 24] = zeroed
    n: mutable i32 = 0
    if v == 0:
        txt_byte(48u8)
        return
    while v > 0:
        tmp[n.usize()] <- (48 + (v % 10).i32()).u8()
        v <- v / 10
        n <- n + 1
    while n > 0:
        n <- n - 1
        txt_byte(tmp[n.usize()])

# Classify a pixel into a single readable char: low-saturation -> luminance ramp,
# otherwise a hue letter (R red, O orange, Y yellow, G green, C cyan, B blue, M magenta),
# uppercase if bright, lowercase if dim.
def color_char(p: u32) -> u8:
    r: i32 = ((p >> 16u32) & 255u32).i32()
    g: i32 = ((p >> 8u32) & 255u32).i32()
    b: i32 = (p & 255u32).i32()
    mx: mutable i32 = r
    if g > mx:
        mx <- g
    if b > mx:
        mx <- b
    mn: mutable i32 = r
    if g < mn:
        mn <- g
    if b < mn:
        mn <- b
    lum: i32 = (r * 3 + g * 6 + b) / 10
    if mx - mn < 28:                            # effectively grayscale
        idx: mutable i32 = lum / 26
        if idx > 9:
            idx <- 9
        return RAMP[idx.usize()]
    # hue bucket by dominant channels
    c: mutable u8 = 0u8
    if r >= g and g >= b:
        if g - b > (r - b) / 2:
            c <- 79u8                            # O orange (red-yellow)
        else:
            c <- 82u8                            # R red
    else:
        if g >= r and r >= b:
            c <- 89u8                            # Y yellow-green side
            if g - r > (g - b) / 2:
                c <- 71u8                        # G green
        else:
            if g >= b and b >= r:
                c <- 71u8                        # G green
                if b - r > (g - r) / 2:
                    c <- 67u8                    # C cyan
            else:
                if b >= g and g >= r:
                    c <- 67u8                    # C cyan
                    if b - g > (b - r) / 2:
                        c <- 66u8                # B blue
                else:
                    if b >= r and r >= g:
                        c <- 66u8                # B blue
                        if r - g > (b - g) / 2:
                            c <- 77u8            # M magenta
                    else:
                        c <- 77u8                # M magenta / pink
    if lum < 110:
        c <- c + 32u8                            # lowercase = dim shade of the hue
    return c

# Box-downscale src (sw x sh) into the ring slot at RING[base..] (dw x dh).
def downscale_into(src: u32&, sw: i32, sh: i32, dw: i32, dh: i32, base: i32) -> void:
    dy: mutable i32 = 0
    while dy < dh:
        y0: i32 = dy * sh / dh
        y1m: i32 = (dy + 1) * sh / dh
        y1: mutable i32 = y1m
        if y1 <= y0:
            y1 <- y0 + 1
        dx: mutable i32 = 0
        while dx < dw:
            x0: i32 = dx * sw / dw
            x1m: i32 = (dx + 1) * sw / dw
            x1: mutable i32 = x1m
            if x1 <= x0:
                x1 <- x0 + 1
            rs: mutable u32 = 0
            gs: mutable u32 = 0
            bs: mutable u32 = 0
            cnt: mutable u32 = 0
            y: mutable i32 = y0
            while y < y1:
                x: mutable i32 = x0
                while x < x1:
                    p: u32 = src[(y * sw + x).usize()]
                    rs <- rs + ((p >> 16u32) & 255u32)
                    gs <- gs + ((p >> 8u32) & 255u32)
                    bs <- bs + (p & 255u32)
                    cnt <- cnt + 1u32
                    x <- x + 1
                y <- y + 1
            RING[(base + dy * dw + dx).usize()] <- ((rs / cnt) << 16u32) | ((gs / cnt) << 8u32) | (bs / cnt)
            dx <- dx + 1
        dy <- dy + 1

# Serialize one frame from the ring into TXT: "FRAME <i> t=<ms>" + ASCII rows,
# plus a COLOR section when with_color != 0 (used for the batch's final frame).
def stage_frame_text(idx: i32, base: i32, dw: i32, dh: i32, t_ms: i64, with_color: i32) -> void:
    txt_len <- 0
    txt_str("FRAME ")
    txt_dec(idx.i64())
    txt_str(" t=")
    txt_dec(t_ms)
    txt_byte(10u8)
    txt_str("ASCII\n")
    ay: mutable i32 = 0
    while ay < dh:
        ax: mutable i32 = 0
        while ax < dw:
            p: u32 = RING[(base + ay * dw + ax).usize()]
            r: u32 = (p >> 16u32) & 255u32
            g: u32 = (p >> 8u32) & 255u32
            b: u32 = p & 255u32
            lum: u32 = (r * 3u32 + g * 6u32 + b) / 10u32
            i: mutable u32 = lum / 26u32
            if i > 9u32:
                i <- 9u32
            txt_byte(RAMP[i.usize()])
            ax <- ax + 1
        txt_byte(10u8)
        ay <- ay + 1
    if with_color != 0:
        txt_str("COLOR\n")
        cy: mutable i32 = 0
        while cy < dh:
            cx: mutable i32 = 0
            while cx < dw:
                txt_byte(color_char(RING[(base + cy * dw + cx).usize()]))
                cx <- cx + 1
            txt_byte(10u8)
            cy <- cy + 1

def write_batch(path: cstr, batch: i64, nframes: i32, dw: i32, dh: i32, fps: i32) -> int:
    f: void&? = fopen(&TMP_PATH[0], "wb".cast[u8&])
    if f is fp:
        # batch header
        txt_len <- 0
        txt_str("BATCH ")
        txt_dec(batch)
        txt_str(" frames=")
        txt_dec(nframes.i64())
        txt_str(" ")
        txt_dec(dw.i64())
        txt_str("x")
        txt_dec(dh.i64())
        txt_str(" fps=")
        txt_dec(fps.i64())
        txt_str(" t0=")
        txt_dec(FRAME_MS[0.usize()])
        txt_byte(10u8)
        _ = fwrite(&TXT[0], 1.usize(), txt_len.usize(), fp)
        # frames (COLOR only on the last one — hue rarely changes within a chunk)
        i: mutable i32 = 0
        while i < nframes:
            wc: mutable i32 = 0
            if i == nframes - 1:
                wc <- 1
            stage_frame_text(i, i * RING_STRIDE, dw, dh, FRAME_MS[i.usize()], wc)
            _ = fwrite(&TXT[0], 1.usize(), txt_len.usize(), fp)
            i <- i + 1
        _ = fclose(fp)
        _ = rename(&TMP_PATH[0], path.cast[u8&])
        return 1
    return 0

def main(argc: int, argv: u8&&) -> int:
    requires argc >= 0
    path: mutable cstr = "/tmp/screen_frames.txt"
    if argc >= 2:
        path <- argv[1].cast[cstr]
    build_tmp_path(path)
    out_w: mutable i32 = 96
    if argc >= 3:
        out_w <- atoi(argv[2]).i32()
    if out_w < 8:
        out_w <- 8
    if out_w > MAX_OUT_W:
        out_w <- MAX_OUT_W
    fps: mutable i32 = 24
    if argc >= 4:
        fps <- atoi(argv[3]).i32()
    if fps < 1:
        fps <- 1
    if fps > 60:
        fps <- 60
    n_seconds: mutable i32 = 3
    if argc >= 5:
        n_seconds <- atoi(argv[4]).i32()
    if n_seconds < 1:
        n_seconds <- 1

    if screencap_start() == 0:
        _ = printf("frame_dump: cannot start capture (Screen Recording permission?)\n".cast[u8&])
        return 1
    if screencap_wait_first_frame() == 0:
        _ = printf("frame_dump: no frames arrived\n".cast[u8&])
        return 1
    sw: i32 = screencap_w()
    sh: i32 = screencap_h()
    if sw * sh > GRAB_CAP:
        _ = printf("frame_dump: display too large\n".cast[u8&])
        return 1
    screencap_log_dims()
    screencap_install_sigint()

    out_h: mutable i32 = out_w * sh / sw
    if out_h < 8:
        out_h <- 8
    if out_w * out_h > RING_STRIDE:
        out_h <- RING_STRIDE / out_w

    batch_frames: mutable i32 = fps * n_seconds
    if batch_frames > MAX_BATCH_FRAMES:
        batch_frames <- MAX_BATCH_FRAMES        # 24fps caps n_seconds at ~10

    _ = printf("frame_dump: recording batches... Ctrl-C to stop.\n".cast[u8&])
    start_ms: i64 = screencap_now_ms()
    frame_interval_ms: i64 = (1000 / fps).i64()
    batch: mutable i64 = 0
    while screencap_should_stop() == 0:
        # ---- fill one batch at the target fps ----
        i: mutable i32 = 0
        next_ms: mutable i64 = screencap_now_ms()
        while i < batch_frames and screencap_should_stop() == 0:
            # busy-ish pacing: sleep until this frame's deadline
            now: mutable i64 = screencap_now_ms()
            while now < next_ms:
                _ = usleep(((next_ms - now) * 1000).u32())
                now <- screencap_now_ms()
            ok: int = screencap_grab(&SCREEN_GRAB[0], GRAB_CAP)
            if ok != 0:
                downscale_into(&SCREEN_GRAB[0], sw, sh, out_w, out_h, i * RING_STRIDE)
                FRAME_MS[i.usize()] <- screencap_now_ms() - start_ms
                i <- i + 1
            next_ms <- next_ms + frame_interval_ms
        if i > 0:
            _ = write_batch(path, batch, i, out_w, out_h, fps)
            batch <- batch + 1
    screencap_stop()
    _ = printf("frame_dump: stopped.\n".cast[u8&])
    return 0
