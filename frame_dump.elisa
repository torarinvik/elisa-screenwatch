# frame_dump.elisa — realtime screen -> framebuffer-as-text, DELTA-ENCODED "video chunk" edition.
#
# Captures the live screen via the pure-Elisa ScreenCaptureKit bridge (screencap.elisa) at a
# fixed FPS into an in-memory ring of downscaled frames. Every n_seconds a whole batch
# (fps * n_seconds frames) is serialized to ONE text file and atomically swapped into place,
# so a polling LLM agent reads a complete "video chunk" and never sees a torn/partial batch.
#
# DELTA ENCODING (the point of this edition): the screen is mostly static at 24fps, so we do
# NOT re-send every frame in full. Each frame is rendered to an ASCII grid, then diffed against
# the previous EMITTED frame:
#   - frame 0 of a batch is always a full KEYFRAME (self-contained; a watcher can drop in cold)
#   - a frame identical to its predecessor emits SAME (a few bytes)
#   - a scrolled frame emits SHIFT dy=<n> + only the newly-revealed / changed rows
#   - otherwise only the changed row-ranges are emitted (ROWS a-b + content)
# Cost therefore scales with CHANGE, not with resolution: a calm screen at 192-wide costs far
# less than the old 96-wide full dump, and high resolution is nearly free where nothing moves.
# A churn guard promotes a heavily-changed frame back to a KEYFRAME (cheaper to state than diff)
# and a token cap degrades the emit rate for pathological full-screen churn (video playback).
#
# Output format (one file per batch, plain text; full contract in SPEC.md):
#   BATCH <b> v=2 frames=<F> <w>x<h> fps=<fps> t0=<ms> cap=<tok>
#   STATS same=<s> shifted=<sh> keyframes=<k> churn_rows=<c> img=<batch_<b>.jpg|none>
#   ACTIVITY <still|typing|scrolling|video|switching> conf=<0-100>
#   KEYFRAME 0 t=<ms>
#   ASCII
#   <h rows of w luminance chars " .:-=+*#%@">
#   COLOR
#   <h rows of hue letters R O Y G C B M (uppercase=bright), grayscale cells use the ramp>
#   FRAME 1 t=<ms>
#   SAME
#   FRAME 2 t=<ms>
#   SHIFT dy=-3            (optional; content shifted 3 rows up since last emitted frame)
#   ROWS 59-61            (one or more changed row-ranges, full row content follows)
#   <rows>
#   ... (KEYFRAME <i> may reappear mid-batch on a churn resync)
#   BATCH_END emitted=<E> changed_rows=<R> bytes=<N> rate=<K>
#
# DIRECTORY OUTPUT / RETAINED HISTORY: batches land in <dir>/batch_<n>.txt with a <dir>/latest.txt
# pointer (both atomic tmp+rename). The last `retain` batches are kept so evidence pointers
# ("batch 214 frame 30") stay resolvable; older batch files are pruned.
#
# USAGE: frame_dump [out_dir] [width] [fps] [n_seconds] [token_cap] [retain] [save_images]
#   out_dir     directory for batch files          (default /tmp/screen_batches)
#   width       downscaled frame width             (default 192; height follows aspect; max 256)
#   fps         capture rate                       (default 24; max 60)
#   n_seconds   batch window in seconds            (default 3; fps*n_seconds capped at 256 frames)
#   token_cap   soft per-batch token budget        (default 40000; degrades emit rate past it)
#   retain      batch files kept on disk           (default 40)
#   save_images 1 = save a full-res keyframe JPEG per batch (active-perception zoom), 0 = off
#
# Written for -Wflow-strict: decisions are values, guards, match arms, or machine transitions.

include "./screencap.elisa"
include "./encoder.elisa"

def main(argc: int, argv: u8&&) -> int:
    requires argc >= 0
    dir: cstr = argv[1].cast[cstr] if argc >= 2 else "/tmp/screen_batches"
    _ = mkdir(dir.cast[u8&], 493)                  # 0o755; ignore EEXIST
    Encoder::build_named_path(&Encoder::LATEST_PATH[0], &Encoder::LATEST_TMP[0], dir, "latest.txt")

    out_w: i32 = Encoder::clamp_i32(Encoder::arg_i32(argc, argv, 2, 192), 8, Encoder::MAX_OUT_W)
    fps: i32 = Encoder::clamp_i32(Encoder::arg_i32(argc, argv, 3, 24), 1, 60)
    n_seconds: i32 = Encoder::at_least(Encoder::arg_i32(argc, argv, 4, 3), 1)
    token_cap: i32 = Encoder::at_least(Encoder::arg_i32(argc, argv, 5, 40000), 2000)
    retain: i32 = Encoder::at_least(Encoder::arg_i32(argc, argv, 6, 40), 1)
    save_images: i32 = 1 if Encoder::arg_i32(argc, argv, 7, 1) != 0 else 0
    arch_mb: i32 = Encoder::at_least(Encoder::arg_i32(argc, argv, 8, 2048), 0)   # Tier A ring byte cap; 0 disables

    Encoder::fail("frame_dump: cannot start capture (Screen Recording permission?)\n") return if Screencap::screencap_start() == 0
    Encoder::fail("frame_dump: no frames arrived\n") return if Screencap::screencap_wait_first_frame() == 0
    sw: i32 = Screencap::screencap_w()
    sh: i32 = Screencap::screencap_h()
    Encoder::fail("frame_dump: display too large\n") return if sw * sh > Encoder::GRAB_CAP
    Screencap::screencap_log_dims()
    Screencap::screencap_install_sigint()

    out_h0: i32 = Encoder::clamp_i32(out_w * sh / sw, 8, 256)   # CHANGED[]/row arrays are 256 deep
    out_h: i32 = Encoder::RING_STRIDE / out_w if out_w * out_h0 > Encoder::RING_STRIDE else out_h0

    # 24fps caps n_seconds at ~10
    batch_frames: i32 = fps * n_seconds if fps * n_seconds <= Encoder::MAX_BATCH_FRAMES else Encoder::MAX_BATCH_FRAMES
    cap_bytes: i32 = token_cap * 4                 # ~4 bytes/token for this content

    _ = printf("frame_dump: delta-encoded batches -> directory. Ctrl-C to stop.\n".cast[u8&])
    Archive::archive_init(dir, arch_mb)
    start_ms: i64 = Screencap::screencap_now_ms()
    frame_interval_ms: i64 = (1000 / fps).i64()
    batch: mutable i64 = 0
    while Screencap::screencap_should_stop() == 0:
        # ---- fill one batch at the target fps ----
        i: mutable i32 = 0
        next_ms: mutable i64 = Screencap::screencap_now_ms()
        while i < batch_frames and Screencap::screencap_should_stop() == 0:
            # pacing: sleep until this frame's deadline, then advance the deadline
            now: mutable i64 = Screencap::screencap_now_ms()
            while now < next_ms:
                _ = usleep(((next_ms - now) * 1000).u32())
                now <- Screencap::screencap_now_ms()
            next_ms <- next_ms + frame_interval_ms
            continue if Screencap::screencap_grab(&Encoder::SCREEN_GRAB[0], Encoder::GRAB_CAP) == 0
            Archive::archive_frame(&Encoder::SCREEN_GRAB[0], sw, sh, Screencap::screencap_now_ms() - start_ms)   # Tier A exact ring
            Encoder::downscale_into(&Encoder::SCREEN_GRAB[0], sw, sh, out_w, out_h, i * Encoder::RING_STRIDE)
            Encoder::write_frame_ppm(dir, batch, sw, sh) if save_images == 1 and i == 0
            Encoder::FRAME_MS[i.usize()] <- Screencap::screencap_now_ms() - start_ms
            i <- i + 1
        continue if i == 0
        _ = Encoder::write_batch_dir(dir, batch, i, out_w, out_h, fps, cap_bytes, retain, token_cap, save_images)
        batch <- batch + 1
    Archive::archive_stop()
    Screencap::screencap_stop()
    _ = printf("frame_dump: stopped.\n".cast[u8&])
    return 0
