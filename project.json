{
  "version": "1",
  "targets": {
    "frame-dump": {
      "entry": "frame_dump.elisa",
      "emit": "obj",
      "run-emit": "obj",
      "output": "frame_dump",
      "opt": "3",
      "link-flags": ["-lobjc", "-lcompression", "-Wl,-framework,ScreenCaptureKit", "-Wl,-framework,CoreMedia", "-Wl,-framework,CoreVideo", "-Wl,-framework,CoreGraphics", "-Wl,-framework,AudioToolbox", "-Wl,-framework,Foundation"]
    },
    "arch-tool": {
      "entry": "arch_tool.elisa",
      "emit": "obj",
      "run-emit": "obj",
      "output": "arch_tool",
      "opt": "3",
      "link-flags": ["-lcompression"]
    },
    "scenegen": {
      "entry": "scenegen.elisa",
      "emit": "obj",
      "run-emit": "obj",
      "output": "scenegen",
      "opt": "3",
      "link-flags": ["-lcompression"]
    },
    "tracker": {
      "entry": "tracker.elisa",
      "emit": "obj",
      "run-emit": "obj",
      "output": "tracker",
      "opt": "3"
    },
    "audiogen": {
      "entry": "audiogen.elisa",
      "emit": "obj",
      "run-emit": "obj",
      "output": "audiogen",
      "opt": "3"
    },
    "audiotriage": {
      "entry": "audiotriage.elisa",
      "emit": "obj",
      "run-emit": "obj",
      "output": "audiotriage",
      "opt": "3"
    }
  }
}
