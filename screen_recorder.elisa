include "./comic_capture.elisa"

# screen_recorder.elisa — record the live macOS desktop into "comic book" contact sheets.
#
# This is the Wolf3D comic recorder, generalized off SDL: instead of being handed an in-memory SDL
# framebuffer, it grabs the real screen each tick via a ScreenCaptureKit C bridge (screencap_bridge.m)
# and feeds those pixels into the exact same project-agnostic comic pipeline (comic_capture.elisa):
# each captured frame is box-downscaled into a panel, panels tile into a grid "page", every panel gets
# a burned-in capture number + timestamp, and full pages are STREAMED to disk the moment they fill —
# so a long recording produces a sequence of <prefix>NNN.png sheets, not one giant file.
#
# It records continuously until you press Ctrl-C (or until an optional max-frame cap), then flushes the
# partially-filled last page so no trailing frames are lost.
#
# USAGE:  screen_rec [out_prefix] [delay_ms] [cols] [rows] [panel_w] [panel_h] [max_frames]
#   out_prefix  page filename prefix          (default /tmp/screen_comic_page -> /tmp/screen_comic_page000.png)
#   delay_ms    pacing: <0 motion-adaptive (default), >0 fixed every N ms, 0 = max speed
#   cols, rows  panels per page grid           (default 3 x 3 = 9 frames/page; max 12 x 12)
#   panel_w/h   downscaled panel pixel size    (default 440 x auto; panel_h 0 = match screen aspect; max 1000 x 560)
#   max_frames  stop after this many frames    (default 0 = unlimited, until Ctrl-C)
#
# The defaults are tuned for an LLM "watching" the screen: a 3x3 page comes out ~1344x876 (~1.18MP),
# right at the vision-input sweet spot, so the contact sheet is read ~1:1 with each panel still
# recognizable. Sampling is MOTION-ADAPTIVE by default: the bridge diffs the 60fps stream and a panel
# is captured only when the screen changes (up to ~7.5fps in heavy action, down to a 2.5s heartbeat when
# idle), concentrating the panel budget on the frames that move. CSV stamp_ms is a real monotonic
# timeline (ms since start). For fixed high-FPS recording, pass a big grid + delay 0, e.g.
#   screen_rec /tmp/p 0 10 10 760 428  -> ~8K pages at ~45fps.
# Requires the "Screen Recording" permission (System Settings -> Privacy & Security -> Screen Recording).

# ---- ScreenCaptureKit capture, driven entirely from Elisa via the Objective-C runtime (no .m file) --
include "./screencap.elisa"

# Motion-adaptive keyframe tuning (used when delay_ms < 0). A panel is captured when accumulated
# motion since the last panel crosses KF_THRESH (but never closer together than KF_MIN_MS, so a
# flurry can't fire every single frame), or every KF_MAX_MS regardless (heartbeat for static scenes).
global KF_MIN_MS: i32 = 130                    # >= ~7.5 keyframes/sec ceiling during heavy action
global KF_MAX_MS: i32 = 2500                   # capture at least every 2.5s even if nothing moves
global KF_THRESH: i32 = 110                    # accumulated mean per-pixel delta to trigger a keyframe
# An accumulated audio-loudness spike (sum of RMS-above-floor since the last keyframe) also forces a
# capture, so a sound event (an impact, a crowd surge) is never missed even if the picture barely moved.
global KF_AUDIO_THRESH: i32 = 1500
global AUDIO_LABEL_LOUD: i32 = 180             # RMS at capture time above this -> panel tagged "loud"
global AUDIO_LABEL_SND: i32 = 70               # ...above this -> tagged "snd"

# ---- libc: file IO used by comic_capture.elisa, plus args for the loop (usleep comes from screencap) -
extern fopen(path: u8&, mode: u8&) -> void&?
extern fwrite(ptr: u8&, size: usize, nmemb: usize, stream: void&) -> usize
extern fclose(stream: void&) -> int
extern atoi(s: u8&) -> int
extern printf(fmt: u8&) -> int

# Source grab buffer: up to 24M pixels (96MB) — covers 4K/5K/6K displays. Global, not a stack local.
global SCREEN_GRAB: array[u32, 24000000] = zeroed
global GRAB_CAP: i32 = 24000000

# The page buffer inside ComicCapture is ~256MB, so it must live as a global, not on the stack.
global mutable g_comic: ComicCapture = zeroed

def main(argc: int, argv: u8&&) -> int:
    requires argc >= 0
    # ---- resolve arguments (all optional, positional) ----
    prefix: mutable cstr = "/tmp/screen_comic_page"
    if argc >= 2:
        prefix <- argv[1].cast[cstr]
    # Defaults are tuned for an LLM "watching" the screen: a 3x3 page sized near the vision sweet
    # spot (~1.1MP / ~1568px long edge) so the contact sheet is shown ~1:1 and each panel stays
    # recognizable, sampled at 2fps so 9 panels cover a ~4.5s "scene". Override any of them positionally.
    # delay_ms < 0 (default) = motion-adaptive: capture a keyframe when the screen actually changes,
    # idle when it doesn't. delay_ms > 0 = fixed-rate (every N ms). delay_ms == 0 = max speed (no pacing).
    delay_ms: mutable i32 = -1
    if argc >= 3:
        delay_ms <- atoi(argv[2]).i32()
    cols: mutable i32 = 3
    if argc >= 4:
        cols <- atoi(argv[3]).i32()
    rows: mutable i32 = 3
    if argc >= 5:
        rows <- atoi(argv[4]).i32()
    panel_w: mutable i32 = 440                     # 3 cols -> ~1338px-wide page, near the vision limit
    if argc >= 6:
        panel_w <- atoi(argv[5]).i32()
    panel_h: mutable i32 = 0                        # 0 = auto-derive from the captured screen's aspect ratio
    if argc >= 7:
        panel_h <- atoi(argv[6]).i32()
    max_frames: mutable i32 = 0
    if argc >= 8:
        max_frames <- atoi(argv[7]).i32()
    if max_frames < 0:
        max_frames <- 0

    # ---- start the capture stream and wait for the first frame (catches missing-permission case) ----
    if screencap_start() == 0:
        _ = printf("screen_rec: cannot start the capture stream (grant Screen Recording permission?)\n".cast[u8&])
        return 1
    if screencap_wait_first_frame() == 0:
        _ = printf("screen_rec: no frames arrived (Screen Recording permission?)\n".cast[u8&])
        return 1
    sw0: i32 = screencap_w()
    sh0: i32 = screencap_h()
    if sw0 * sh0 > GRAB_CAP:
        _ = printf("screen_rec: display too large for the capture buffer\n".cast[u8&])
        screencap_stop()
        return 1

    screencap_log_dims()
    screencap_install_sigint()

    # Auto-derive panel height from the captured screen's aspect ratio (so panels aren't distorted),
    # unless the caller passed an explicit panel_h. comic_init clamps to CC_MAX_PANEL_H.
    if panel_h <= 0:
        if sw0 > 0:
            panel_h <- panel_w * sh0 / sw0
        if panel_h < 16:
            panel_h <- 16

    # let a loud audio spike force a keyframe (only meaningful in motion-adaptive mode)
    screencap_set_audio_trigger(KF_AUDIO_THRESH)

    # interval 1: capture every grab (we pace capture ourselves below)
    comic_init(&g_comic, prefix, panel_w, panel_h, cols, rows, 1)
    if delay_ms < 0:
        _ = printf("screen_rec: recording (motion-adaptive)... press Ctrl-C to stop and flush.\n".cast[u8&])
    else:
        _ = printf("screen_rec: recording... press Ctrl-C to stop and flush the final page.\n".cast[u8&])

    start_ms: i64 = screencap_now_ms()            # real monotonic timeline -> true timestamps in the CSV
    f: mutable i32 = 0
    while screencap_should_stop() == 0:
        if max_frames > 0 and f >= max_frames:
            break
        # Pace BEFORE the grab so the keyframe gate fires on a fresh, just-changed frame.
        if delay_ms < 0:
            _ = screencap_wait_keyframe(KF_MIN_MS, KF_MAX_MS, KF_THRESH)
        ok: int = screencap_grab(&SCREEN_GRAB[0], GRAB_CAP)
        if ok != 0:
            w: i32 = screencap_w()
            h: i32 = screencap_h()
            stamp: i32 = (screencap_now_ms() - start_ms).i32()   # ms since recording started
            # tag the panel/CSV row with the audio level at capture time (cheap audio-event signal)
            alvl: i32 = screencap_audio_level()
            albl: mutable cstr = ""
            if alvl >= AUDIO_LABEL_LOUD:
                albl <- "loud"
            else:
                if alvl >= AUDIO_LABEL_SND:
                    albl <- "snd"
            comic_capture_rgb(&g_comic, &SCREEN_GRAB[0], w, h, stamp, alvl.u32(), albl)
        if delay_ms > 0:
            _ = usleep((delay_ms * 1000).u32())
        f <- f + 1

    screencap_stop()
    comic_flush(&g_comic)
    _ = printf("screen_rec: stopped; pages flushed.\n".cast[u8&])
    return 0
