# audiogen.elisa — deterministic audio-scene synthesizer, the audio twin of scenegen (orchestra_v2
# plan M5). Renders scripted audio scenes to a 16 kHz mono s16le WAV so the cymbal (audiotriage) can
# be trap-tested with exact-by-construction ground truth — and, where a machine can play sound, the
# same WAV drives the real system-audio capture path. Time is synthetic (sample i == t = i/16000 s),
# so two runs are byte-identical.
#
# USAGE: audiogen <scene> [out.wav]
#   scene   transient-in-noise | silence-gap | level-ramp | tone-alarm | av-sync
#   out.wav output path (default /tmp/audiogen.wav)

extern fopen(path: u8&, mode: u8&) -> heap void&?
extern fwrite(ptr: u8&, size: usize, nmemb: usize, stream: void&) -> usize
extern fclose(stream: void&) -> int
extern printf(fmt: u8&) -> int
extern sin(x: f64) -> f64

global SR: i32 = 16000
global mutable SAMP: array[i16, 960000] = zeroed     # up to 60 s mono
global mutable nsamp: i32 = 0
global mutable rng: u64 = 88172645463325252          # xorshift64 seed (no overflow-trap ops)

def streq(a: u8&, b: cstr) -> bool:
    i: mutable i32 = 0
    while a[i.usize()] != 0 and b[i.usize()] != 0:
        false return if a[i.usize()] != b[i.usize()]
        i <- i + 1
    return a[i.usize()] == b[i.usize()]

# xorshift64 — shifts + XOR only, so no wrapping-arithmetic trap; deterministic per seed.
def rnd() -> u64:
    x: mutable u64 = rng
    x <- x ^ (x << 13)
    x <- x ^ (x >> 7)
    x <- x ^ (x << 17)
    rng <- x
    return x

# a signed pseudo-random sample in [-amp, amp]
def noise_sample(amp: i32) -> i32:
    r: u64 = rnd()
    v: i32 = (r & 65535).i32() - 32768       # [-32768, 32767]
    return v * amp / 32768

def clamp16(v: i32) -> i16:
    c: i32 = -32768 if v < -32768 else (32767 if v > 32767 else v)
    return c.i16()

def add_sample(k: i32, v: i32) -> void:
    return if k < 0 or k >= 960000
    SAMP[k.usize()] <- clamp16(SAMP[k.usize()].i32() + v)

def ms_to_samples(ms: i32) -> i32:
    return ms * SR / 1000

# ---- synthesis primitives (each ADDS into SAMP over [off, off+n)) ----

def add_tone(off: i32, n: i32, freq: i32, amp: i32) -> void:
    twopi: f64 = 6.283185307179586
    for i in 0..<n:
        ph: f64 = twopi * freq.f64() * i.f64() / 16000.0
        add_sample(off + i, (amp.f64() * sin(ph)).i32())

def add_noise(off: i32, n: i32, amp: i32) -> void:
    for i in 0..<n:
        add_sample(off + i, noise_sample(amp))

# noise whose amplitude ramps linearly amp0 -> amp1 across the window (the music-intensity proxy)
def add_noise_ramp(off: i32, n: i32, amp0: i32, amp1: i32) -> void:
    for i in 0..<n:
        a: i32 = amp0 + (amp1 - amp0) * i / n
        add_sample(off + i, noise_sample(a))

# a short impact: full-amp noise with a linear decay envelope to 0 across n samples
def add_impact(off: i32, n: i32, amp: i32) -> void:
    for i in 0..<n:
        env: i32 = amp * (n - i) / n
        add_sample(off + i, noise_sample(env))

# ---- scenes (all 20 s unless noted; return total samples) ----

def scene_transient_in_noise() -> i32:
    total: i32 = 20 * SR
    add_noise(0, total, 1200)                            # quiet pink-ish bed (-~28 dBFS)
    add_impact(ms_to_samples(4000), ms_to_samples(12), 26000)    # impact @ 4.00 s
    add_impact(ms_to_samples(9000), ms_to_samples(12), 26000)    # impact @ 9.00 s
    add_impact(ms_to_samples(9150), ms_to_samples(12), 26000)    # impact @ 9.15 s (150 ms later)
    return total

def scene_silence_gap() -> i32:
    total: i32 = 20 * SR
    add_tone(0, total, 220, 9000)                        # steady 220 Hz bed
    g0: i32 = ms_to_samples(7000)
    gn: i32 = ms_to_samples(800)
    for i in 0..<gn:
        SAMP[(g0 + i).usize()] <- 0                      # exact 800 ms silence @ 7.00 s
    return total

def scene_level_ramp() -> i32:
    total: i32 = 20 * SR
    lo: i32 = 2500
    add_noise(0, ms_to_samples(8000), lo)                # steady low bed 0-8 s
    add_noise_ramp(ms_to_samples(8000), ms_to_samples(3000), lo, lo * 28 / 10)   # +~9 dB over 3 s
    add_noise(ms_to_samples(11000), total - ms_to_samples(11000), lo * 28 / 10)  # loud bed after
    return total

def scene_tone_alarm() -> i32:
    total: i32 = 20 * SR
    add_tone(ms_to_samples(2000), ms_to_samples(200), 1000, 14000)   # beep @ 2 s
    add_tone(ms_to_samples(4000), ms_to_samples(200), 1000, 14000)   # beep @ 4 s
    add_tone(ms_to_samples(6000), ms_to_samples(200), 1000, 14000)   # beep @ 6 s
    return total

def scene_av_sync() -> i32:
    total: i32 = 20 * SR
    add_impact(ms_to_samples(10000), ms_to_samples(10), 30000)       # single impact @ exactly 10.000 s
    return total

# ---- WAV writer (16 kHz mono s16le) ----

def put16le(buf: mutable u8&, off: i32, v: i32) -> void:
    buf[off.usize()] <- (v & 255).u8()
    buf[(off + 1).usize()] <- ((v >> 8) & 255).u8()

def put32le(buf: mutable u8&, off: i32, v: i32) -> void:
    buf[off.usize()] <- (v & 255).u8()
    buf[(off + 1).usize()] <- ((v >> 8) & 255).u8()
    buf[(off + 2).usize()] <- ((v >> 16) & 255).u8()
    buf[(off + 3).usize()] <- ((v >> 24) & 255).u8()

global mutable HDR: array[u8, 44] = zeroed

def write_wav(path: cstr) -> i32:
    datalen: i32 = nsamp * 2
    HDR[0.usize()] <- 82         # R
    HDR[1.usize()] <- 73         # I
    HDR[2.usize()] <- 70         # F
    HDR[3.usize()] <- 70         # F
    put32le(&HDR[0], 4, 36 + datalen)
    HDR[8.usize()] <- 87         # W
    HDR[9.usize()] <- 65         # A
    HDR[10.usize()] <- 86        # V
    HDR[11.usize()] <- 69        # E
    HDR[12.usize()] <- 102       # f
    HDR[13.usize()] <- 109       # m
    HDR[14.usize()] <- 116       # t
    HDR[15.usize()] <- 32        # (space)
    put32le(&HDR[0], 16, 16)     # fmt chunk size
    put16le(&HDR[0], 20, 1)      # PCM
    put16le(&HDR[0], 22, 1)      # mono
    put32le(&HDR[0], 24, SR)     # sample rate
    put32le(&HDR[0], 28, SR * 2) # byte rate
    put16le(&HDR[0], 32, 2)      # block align
    put16le(&HDR[0], 34, 16)     # bits/sample
    HDR[36.usize()] <- 100       # d
    HDR[37.usize()] <- 97        # a
    HDR[38.usize()] <- 116       # t
    HDR[39.usize()] <- 97        # a
    put32le(&HDR[0], 40, datalen)
    f0: void&? = fopen(path.cast[u8&], "wb".cast[u8&])
    if f0 is f:
        _ = fwrite(&HDR[0], 1.usize(), 44.usize(), f)
        trusted Unsafe.PointerCast:                       # reinterpret the s16 buffer as bytes to write
            _ = fwrite((&SAMP[0]).cast[u8&], 2.usize(), nsamp.usize(), f)
        _ = fclose(f)
        return 0
    return 1

def main(argc: int, argv: u8&&) -> int:
    requires argc >= 0
    scene: u8& = argv[1] if argc >= 2 else "transient-in-noise".cast[u8&]
    out: cstr = argv[2].cast[cstr] if argc >= 3 else "/tmp/audiogen.wav"
    if streq(scene, "transient-in-noise"):
        nsamp <- scene_transient_in_noise()
    else:
        if streq(scene, "silence-gap"):
            nsamp <- scene_silence_gap()
        else:
            if streq(scene, "level-ramp"):
                nsamp <- scene_level_ramp()
            else:
                if streq(scene, "tone-alarm"):
                    nsamp <- scene_tone_alarm()
                else:
                    if streq(scene, "av-sync"):
                        nsamp <- scene_av_sync()
                    else:
                        _ = printf("audiogen: unknown scene (transient-in-noise|silence-gap|level-ramp|tone-alarm|av-sync)\n".cast[u8&])
                        return 2
    r: i32 = write_wav(out)
    if r == 0:
        _ = printf("audiogen: wrote WAV\n".cast[u8&])
    else:
        _ = printf("audiogen: write failed\n".cast[u8&])
    return r