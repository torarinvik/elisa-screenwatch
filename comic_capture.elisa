# comic_capture.elisa — reusable "comic book" screenshot recorder for any Elisa + SDL project.
#
# WHY: a vision model (Claude) can read still images but not watch live gameplay. This library turns a
# running SDL game into a sequence of "comic pages": each page is a grid of downscaled panels captured
# at a fixed interval, in time order, with the capture number burned into each panel. Reading one page
# lets the model reconstruct motion the way a comic strip conveys action across panels.
#
# IT IS PROJECT-AGNOSTIC. The only thing it touches is the RGB framebuffer every SDL project already
# builds before SDL_UpdateTexture: a tightly packed array of 0x00RRGGBB pixels, `src_w` * `src_h`.
# (In Wolf3D that is `pixels[]`; in any other Elisa+SDL game it is whatever you hand to the texture.)
#
# USAGE (three lines in the host):
#     cc: mutable ComicCapture = zeroed
#     comic_init(&cc, "/abs/path/to/out/page", 160, 100, 3, 3, 6)   # 3x3 panels, every 6th frame
#     ... per frame, right before/after SDL_UpdateTexture:
#     comic_capture_rgb(&cc, &pixels[0], VIEWWIDTH, SCREENHEIGHT)
#     ... on exit (flush the partially-filled last page):
#     comic_flush(&cc)
#
# OUTPUT: <prefix>NNN.png — true PNG (RGB8, stored/uncompressed zlib), readable directly by the model.

# NOTE: fopen/fwrite/fclose are provided by the host project (wolf_data.elisa) — the project build
# compiles all sibling .elisa as one dedup'd unit, so this file must NOT redeclare them. (If you drop
# this library into a project that lacks them, add the externs there, matching: fopen -> void&?,
# fwrite(ptr:u8&, size:usize, nmemb:usize, stream:void&) -> usize, fclose(stream:void&) -> int.)

# ---- capacity caps. The page buffer is large (8K+ contact sheets, ~256MB), so a ComicCapture must
# be a GLOBAL, not a stack local (it would obliterate the stack). --------------------------------------
global CC_MAX_PANEL_W: i32 = 1000               # high-res screen panels
global CC_MAX_PANEL_H: i32 = 560
global CC_MAX_COLS: i32 = 12
global CC_MAX_ROWS: i32 = 12                     # up to 12x12 = 144 panels per sheet
global CC_GUTTER: i32 = 6
global CC_LABEL_MAX: i32 = 80                   # caller label buffers are array[u8,80]; cc_meta_row caps its cstr scan here
# max page = gutter + cols*(panel+gutter) = 6 + 12*(1000+6) = 12078 wide ; 6 + 12*(560+6) = 6798 tall
# -> 12078 * 6798 * 3 bytes = 246,318,732. Cap at 256,000,000 with headroom.
# (The 10x10 @ 760x428 default -> 7666x4346, a ~8K page, sits well within this.)
global CC_MAX_PAGE_BYTES: i32 = 256000000

# 3x5 bitmap font, digits 0-9, one byte per row (low 3 bits, MSB = leftmost column).
global CC_FONT: array[u8, 50] = [
    7u8,5u8,5u8,5u8,7u8,   2u8,6u8,2u8,2u8,7u8,   7u8,1u8,7u8,4u8,7u8,   7u8,1u8,7u8,1u8,7u8,
    5u8,5u8,7u8,1u8,1u8,   7u8,4u8,7u8,1u8,7u8,   7u8,4u8,7u8,5u8,7u8,   7u8,1u8,2u8,2u8,2u8,
    7u8,5u8,7u8,5u8,7u8,   7u8,5u8,7u8,1u8,7u8]

struct ComicCapture layout(c):
    cols: mutable i32
    rows: mutable i32
    panel_w: mutable i32
    panel_h: mutable i32
    interval: mutable i32          # capture one frame out of every `interval` calls
    tick: mutable i32              # rolling frame counter (mod interval)
    panel_idx: mutable i32         # next free panel slot on the current page (0 .. cols*rows-1)
    page_idx: mutable i32          # page number, drives the output filename
    seq: mutable i32               # global capture counter (number burned into each panel)
    page_w: mutable i32            # computed page pixel width
    page_h: mutable i32            # computed page pixel height
    prefix: mutable cstr
    meta_f: mutable void&?         # sidecar CSV: one row per captured panel (seq,page,panel,stamp,keys)
    page_rgb: mutable array[u8, 256000000]  # packed RGB8 page being assembled (CC_MAX_PAGE_BYTES)
    invariant self.cols >= 0
    invariant self.rows >= 0
    invariant self.panel_w >= 0
    invariant self.panel_h >= 0
    invariant self.interval >= 0
    invariant self.tick >= 0
    invariant self.panel_idx >= 0
    invariant self.page_idx >= 0
    invariant self.seq >= 0
    invariant self.page_w >= 0
    invariant self.page_h >= 0

# Streaming PNG writer: buffers output and maintains the running IDAT CRC so we never hold the whole
# encoded file in memory (only the raw RGB page above).
struct PngW layout(c):
    f: mutable void&?
    crc: mutable u32
    buf: mutable array[u8, 16384]
    n: mutable i32
    invariant self.n >= 0 and self.n <= 16384

# ---- configuration ---------------------------------------------------------------------------------
# panel_w/h = downscaled panel size; cols*rows = frames per page; interval = capture every Nth frame.
def comic_init(c: mutable ComicCapture&, prefix: cstr, panel_w: i32, panel_h: i32,
               cols: i32, rows: i32, interval: i32) -> void:
    pw: mutable i32 = panel_w
    ph: mutable i32 = panel_h
    nc: mutable i32 = cols
    nr: mutable i32 = rows
    iv: mutable i32 = interval
    if pw < 16: pw <- 16
    if pw > CC_MAX_PANEL_W: pw <- CC_MAX_PANEL_W
    if ph < 16: ph <- 16
    if ph > CC_MAX_PANEL_H: ph <- CC_MAX_PANEL_H
    if nc < 1: nc <- 1
    if nc > CC_MAX_COLS: nc <- CC_MAX_COLS
    if nr < 1: nr <- 1
    if nr > CC_MAX_ROWS: nr <- CC_MAX_ROWS
    if iv < 1: iv <- 1
    c.panel_w <- pw
    c.panel_h <- ph
    c.cols <- nc
    c.rows <- nr
    c.interval <- iv
    c.tick <- 0
    c.panel_idx <- 0
    c.page_idx <- 0
    c.seq <- 0
    c.prefix <- prefix
    c.page_w <- CC_GUTTER + nc * (pw + CC_GUTTER)
    c.page_h <- CC_GUTTER + nr * (ph + CC_GUTTER)
    # sidecar metadata file: "<prefix>_frames.csv" — one row per captured panel
    mpath: mutable array[u8, 256] = zeroed
    mp: mutable i32 = 0
    while prefix[mp.u32()] != 0u8 and mp < 230:
        mpath[mp.usize()] <- prefix[mp.u32()]
        mp <- mp + 1
    suffix: cstr = "_frames.csv"
    si: mutable i32 = 0
    while suffix[si.u32()] != 0u8:
        mpath[(mp + si).usize()] <- suffix[si.u32()]
        si <- si + 1
    mpath[(mp + si).usize()] <- 0u8
    c.meta_f <- fopen(&mpath[0], "wb".cast[u8&])
    if c.meta_f != null:
        hdr: cstr = "seq,page,panel,stamp_ms,keymask,keys\n"
        hi: mutable i32 = 0
        while hdr[hi.u32()] != 0u8:
            hi <- hi + 1
        _ = fwrite(hdr.cast[u8&], 1.usize(), hi.usize(), c.meta_f)

# ---- page raster helpers ---------------------------------------------------------------------------
def cc_set_px(c: mutable ComicCapture&, x: i32, y: i32, rr: u8, gg: u8, bb: u8) -> void:
    if x < 0 or y < 0 or x >= c.page_w or y >= c.page_h:
        return
    o: i32 = (y * c.page_w + x) * 3
    c.page_rgb[o.usize()] <- rr
    c.page_rgb[(o + 1).usize()] <- gg
    c.page_rgb[(o + 2).usize()] <- bb

def cc_fill_page(c: mutable ComicCapture&, rr: u8, gg: u8, bb: u8) -> void:
    n: i32 = c.page_w * c.page_h
    for i in 0..<n:
        o: i32 = i * 3
        c.page_rgb[o.usize()] <- rr
        c.page_rgb[(o + 1).usize()] <- gg
        c.page_rgb[(o + 2).usize()] <- bb

# one decimal digit at (x,y), `s` pixels per font cell
def cc_digit(c: mutable ComicCapture&, d: i32, x: i32, y: i32, s: i32, rr: u8, gg: u8, bb: u8) -> void:
    requires d >= 0 and d <= 9
    requires s >= 1
    for row in 0..<5:
        bits: i32 = CC_FONT[(d * 5 + row).usize()].i32()
        for col in 0..<3:
            if (bits >> (2 - col)) & 1 != 0:
                for dy in 0..<s:
                    for dx in 0..<s:
                        cc_set_px(c, x + col * s + dx, y + row * s + dy, rr, gg, bb)

# non-negative integer, left-aligned at (x,y)
def cc_int(c: mutable ComicCapture&, val: i32, x: i32, y: i32, s: i32, rr: u8, gg: u8, bb: u8) -> void:
    requires s >= 1
    digs: mutable array[i32, 12] = zeroed
    nd: mutable i32 = 0
    n: mutable i32 = val
    if n < 0:
        n <- 0
    if n == 0:
        digs[0u32] <- 0
        nd <- 1
    while n > 0 and nd < 12:
        digs[nd.usize()] <- n % 10
        n <- n / 10
        nd <- nd + 1
    # digs are reversed (least significant first); render most significant first
    cx: mutable i32 = x
    i: mutable i32 = nd - 1
    while i >= 0:
        cc_digit(c, digs[i.usize()], cx, y, s, rr, gg, bb)
        cx <- cx + 4 * s
        i <- i - 1

# Box-downscale the source RGB buffer (sw x sh, 0x00RRGGBB) into panel slot `slot` on the page.
def cc_blit_panel(c: mutable ComicCapture&, pixels: u32&, sw: i32, sh: i32, slot: i32) -> void:
    requires sw >= 1
    requires sh >= 1
    requires slot >= 0
    col: i32 = slot % c.cols
    row: i32 = slot / c.cols
    ox: i32 = CC_GUTTER + col * (c.panel_w + CC_GUTTER)
    oy: i32 = CC_GUTTER + row * (c.panel_h + CC_GUTTER)
    for py in 0..<c.panel_h:
        sy0: i32 = py * sh / c.panel_h
        sy1: mutable i32 = (py + 1) * sh / c.panel_h
        if sy1 <= sy0:
            sy1 <- sy0 + 1
        for px in 0..<c.panel_w:
            sx0: i32 = px * sw / c.panel_w
            sx1: mutable i32 = (px + 1) * sw / c.panel_w
            if sx1 <= sx0:
                sx1 <- sx0 + 1
            rsum: mutable i32 = 0
            gsum: mutable i32 = 0
            bsum: mutable i32 = 0
            cnt: mutable i32 = 0
            for sy in sy0..<sy1:
                for sx in sx0..<sx1:
                    p: u32 = pixels[(sy * sw + sx).usize()]
                    rsum <- rsum + ((p >> 16u32) & 0xFFu32).i32()
                    gsum <- gsum + ((p >> 8u32) & 0xFFu32).i32()
                    bsum <- bsum + (p & 0xFFu32).i32()
                    cnt <- cnt + 1
            if cnt < 1:
                cnt <- 1
            cc_set_px(c, ox + px, oy + py, (rsum / cnt).u8(), (gsum / cnt).u8(), (bsum / cnt).u8())
    # burn the capture index into the panel's top-left corner, on a dark plate for legibility
    plate_w: i32 = 4 * 6 + 2          # room for up to a couple digits at scale 2
    for yy in 0..<11:
        for xx in 0..<plate_w:
            cc_set_px(c, ox + xx, oy + yy, 0u8, 0u8, 0u8)
    cc_int(c, c.seq, ox + 2, oy + 1, 2, 255u8, 230u8, 40u8)

# ---- PNG encoder (RGB8, stored/uncompressed zlib) --------------------------------------------------
def pw_flush(w: mutable PngW&) -> void:
    if w.n > 0 and w.f != null:
        _ = fwrite(&w.buf[0], 1.usize(), w.n.usize(), w.f)
        w.n <- 0

def pw_byte(w: mutable PngW&, b: u8) -> void:
    w.buf[w.n.usize()] <- b
    w.n <- w.n + 1
    if w.n >= 16384:
        pw_flush(w)

# emit a byte that is part of an IDAT chunk: write it AND fold it into the running chunk CRC
def pw_crc_byte(w: mutable PngW&, b: u8) -> void:
    cc: mutable u32 = w.crc ^ b.u32()
    for _ in 0..<8:
        if (cc & 1u32) != 0u32:
            cc <- (cc >> 1u32) ^ 0xEDB88320u32
        else:
            cc <- cc >> 1u32
    w.crc <- cc
    pw_byte(w, b)

def pw_be32(w: mutable PngW&, v: u32) -> void:
    pw_byte(w, ((v >> 24u32) & 0xFFu32).u8())
    pw_byte(w, ((v >> 16u32) & 0xFFu32).u8())
    pw_byte(w, ((v >> 8u32) & 0xFFu32).u8())
    pw_byte(w, (v & 0xFFu32).u8())

# CRC over a small in-memory chunk (type bytes + data); returns finalized CRC
def cc_crc_mem(buf: u8&, len: i32) -> u32:
    requires len >= 0
    cc: mutable u32 = 0xFFFFFFFFu32
    for i in 0..<len:
        cc <- cc ^ buf[i.usize()].u32()
        for _ in 0..<8:
            if (cc & 1u32) != 0u32:
                cc <- (cc >> 1u32) ^ 0xEDB88320u32
            else:
                cc <- cc >> 1u32
    return cc ^ 0xFFFFFFFFu32

# Read raw (filtered) PNG byte at stream index `i`: each scanline is [filter=0][R,G,B...].
def cc_raw_byte(c: ComicCapture&, i: i32) -> u8:
    requires i >= 0
    stride: i32 = 1 + c.page_w * 3
    row: i32 = i / stride
    off: i32 = i % stride
    if off == 0:
        return 0u8                      # filter type 0 (None)
    p: i32 = off - 1
    x: i32 = p / 3
    ch: i32 = p % 3
    return c.page_rgb[((row * c.page_w + x) * 3 + ch).usize()]

# Write the assembled page to <prefix>NNN.png.
def cc_write_png(c: mutable ComicCapture&) -> void:
    # build the filename: prefix + 3-digit page + ".png"
    path: mutable array[u8, 256] = zeroed
    p: mutable i32 = 0
    while c.prefix[p.u32()] != 0u8 and p < 240:
        path[p.usize()] <- c.prefix[p.u32()]
        p <- p + 1
    nn: i32 = c.page_idx
    path[p.usize()] <- (48 + (nn / 100) % 10).u8()
    path[(p + 1).usize()] <- (48 + (nn / 10) % 10).u8()
    path[(p + 2).usize()] <- (48 + nn % 10).u8()
    path[(p + 3).usize()] <- 46u8     # .
    path[(p + 4).usize()] <- 112u8    # p
    path[(p + 5).usize()] <- 110u8    # n
    path[(p + 6).usize()] <- 103u8    # g
    path[(p + 7).usize()] <- 0u8

    w: mutable PngW = zeroed
    w.f <- fopen(&path[0], "wb".cast[u8&])
    if w.f == null:
        return
    w.n <- 0

    # 8-byte PNG signature
    sig: array[u8, 8] = [137u8, 80u8, 78u8, 71u8, 13u8, 10u8, 26u8, 10u8]
    for i in 0..<8:
        pw_byte(&w, sig[i.usize()])

    # IHDR: width, height, bitdepth=8, colortype=2 (RGB), 0,0,0
    ihdr: mutable array[u8, 17] = zeroed
    ihdr[0u32] <- 73u8     # I
    ihdr[1u32] <- 72u8     # H
    ihdr[2u32] <- 68u8     # D
    ihdr[3u32] <- 82u8     # R
    pwid: u32 = c.page_w.u32()
    phei: u32 = c.page_h.u32()
    ihdr[4u32] <- ((pwid >> 24u32) & 0xFFu32).u8()
    ihdr[5u32] <- ((pwid >> 16u32) & 0xFFu32).u8()
    ihdr[6u32] <- ((pwid >> 8u32) & 0xFFu32).u8()
    ihdr[7u32] <- (pwid & 0xFFu32).u8()
    ihdr[8u32] <- ((phei >> 24u32) & 0xFFu32).u8()
    ihdr[9u32] <- ((phei >> 16u32) & 0xFFu32).u8()
    ihdr[10u32] <- ((phei >> 8u32) & 0xFFu32).u8()
    ihdr[11u32] <- (phei & 0xFFu32).u8()
    ihdr[12u32] <- 8u8     # bit depth
    ihdr[13u32] <- 2u8     # color type RGB
    ihdr[14u32] <- 0u8
    ihdr[15u32] <- 0u8
    ihdr[16u32] <- 0u8
    pw_be32(&w, 13u32)
    for i in 0..<17:
        pw_byte(&w, ihdr[i.usize()])
    pw_be32(&w, cc_crc_mem(&ihdr[0], 17))

    # IDAT: zlib(stored deflate) of the raw scanlines. Length is fully predictable up front.
    raw_len: i32 = c.page_h * (1 + c.page_w * 3)
    nblocks: mutable i32 = (raw_len + 65534) / 65535
    if nblocks < 1:
        nblocks <- 1
    idat_len: i32 = 2 + nblocks * 5 + raw_len + 4
    pw_be32(&w, idat_len.u32())
    w.crc <- 0xFFFFFFFFu32
    pw_crc_byte(&w, 73u8)   # I
    pw_crc_byte(&w, 68u8)   # D
    pw_crc_byte(&w, 65u8)   # A
    pw_crc_byte(&w, 84u8)   # T
    # zlib header
    pw_crc_byte(&w, 0x78u8)
    pw_crc_byte(&w, 0x01u8)
    # stored deflate blocks + adler32 over the raw bytes
    a: mutable u32 = 1u32
    b: mutable u32 = 0u32
    pos: mutable i32 = 0
    while pos < raw_len:
        blen: mutable i32 = raw_len - pos
        if blen > 65535:
            blen <- 65535
        final: mutable u8 = 0u8
        if pos + blen >= raw_len:
            final <- 1u8
        pw_crc_byte(&w, final)
        pw_crc_byte(&w, (blen & 0xFF).u8())
        pw_crc_byte(&w, ((blen >> 8) & 0xFF).u8())
        nlen: i32 = (~blen) & 0xFFFF
        pw_crc_byte(&w, (nlen & 0xFF).u8())
        pw_crc_byte(&w, ((nlen >> 8) & 0xFF).u8())
        for k in 0..<blen:
            rb: u8 = cc_raw_byte(c, pos + k)
            a <- (a + rb.u32()) % 65521u32
            b <- (b + a) % 65521u32
            pw_crc_byte(&w, rb)
        pos <- pos + blen
    # adler32, big-endian
    pw_crc_byte(&w, ((b >> 8u32) & 0xFFu32).u8())
    pw_crc_byte(&w, (b & 0xFFu32).u8())
    pw_crc_byte(&w, ((a >> 8u32) & 0xFFu32).u8())
    pw_crc_byte(&w, (a & 0xFFu32).u8())
    pw_be32(&w, w.crc ^ 0xFFFFFFFFu32)

    # IEND
    iend: array[u8, 4] = [73u8, 69u8, 78u8, 68u8]   # IEND
    pw_be32(&w, 0u32)
    for i in 0..<4:
        pw_byte(&w, iend[i.usize()])
    pw_be32(&w, cc_crc_mem(&iend[0], 4))

    pw_flush(&w)
    if w.f != null:
        _ = fclose(w.f)

# write the decimal form of `v` into buf at `pos`; return the new position
def cc_putint(buf: mutable u8&, pos: i32, v: u32) -> i32:
    requires pos >= 0
    ensure result > pos
    digs: mutable array[u8, 12] = zeroed
    nd: mutable i32 = 0
    n: mutable u32 = v
    if n == 0u32:
        digs[0u32] <- 48u8
        nd <- 1
    while n > 0u32 and nd < 12:
        digs[nd.usize()] <- (48u32 + (n % 10u32)).u8()
        n <- n / 10u32
        nd <- nd + 1
    p: mutable i32 = pos
    i: mutable i32 = nd - 1
    while i >= 0:
        buf[p.usize()] <- digs[i.usize()]
        p <- p + 1
        i <- i - 1
    return p

# append one CSV row "seq,page,panel,stamp_ms,keymask,keys" for the panel just captured
def cc_meta_row(c: mutable ComicCapture&, stamp: i32, keymask: u32, label: cstr) -> void:
    if c.meta_f == null:
        return
    buf: mutable array[u8, 320] = zeroed
    p: mutable i32 = 0
    p <- cc_putint(&buf[0], p, c.seq.u32())
    buf[p.usize()] <- 44u8                     # ,
    p <- p + 1
    p <- cc_putint(&buf[0], p, c.page_idx.u32())
    buf[p.usize()] <- 44u8
    p <- p + 1
    p <- cc_putint(&buf[0], p, c.panel_idx.u32())
    buf[p.usize()] <- 44u8
    p <- p + 1
    sv: mutable i32 = stamp
    if sv < 0:
        sv <- 0
    p <- cc_putint(&buf[0], p, sv.u32())
    buf[p.usize()] <- 44u8
    p <- p + 1
    p <- cc_putint(&buf[0], p, keymask)
    buf[p.usize()] <- 44u8
    p <- p + 1
    # Bound the label scan by CC_LABEL_MAX: `label` is an unbounded cstr cast from a fixed
    # CC_LABEL_MAX-byte caller buffer, so without this cap a label with no NUL in the first
    # CC_LABEL_MAX bytes would read off the end of that buffer (out-of-bounds). p<318 only
    # bounds the output buffer, not the input scan.
    li: mutable i32 = 0
    while li < CC_LABEL_MAX and label[li.u32()] != 0u8 and p < 318:
        buf[p.usize()] <- label[li.u32()]
        p <- p + 1
        li <- li + 1
    buf[p.usize()] <- 10u8                     # newline
    p <- p + 1
    _ = fwrite(&buf[0], 1.usize(), p.usize(), c.meta_f)

# burn the timestamp (under the seq plate) and an 8-cell key-state strip onto panel `slot`
def cc_burn_annot(c: mutable ComicCapture&, slot: i32, stamp: i32, keymask: u32) -> void:
    requires slot >= 0
    col: i32 = slot % c.cols
    row: i32 = slot / c.cols
    ox: i32 = CC_GUTTER + col * (c.panel_w + CC_GUTTER)
    oy: i32 = CC_GUTTER + row * (c.panel_h + CC_GUTTER)
    # timestamp on a dark plate just below the seq plate (scale 1, pale blue)
    for yy in 11..<18:
        for xx in 0..<32:
            cc_set_px(c, ox + xx, oy + yy, 0u8, 0u8, 0u8)
    cc_int(c, stamp, ox + 1, oy + 12, 1, 150u8, 200u8, 255u8)
    # 8-cell key strip along the top-right: lit (green) if the bit is set, else dark
    sx: i32 = ox + 4 * 6 + 4              # right of the seq plate
    for k in 0..<8:
        on: bool = ((keymask >> k.u32()) & 1u32) != 0u32
        rr: mutable u8 = 40u8
        gg: mutable u8 = 40u8
        bb: mutable u8 = 40u8
        if on:
            rr <- 40u8
            gg <- 255u8
            bb <- 40u8
        for yy in 0..<5:
            for xx in 0..<4:
                cc_set_px(c, sx + k * 5 + xx, oy + 1 + yy, rr, gg, bb)

# ---- public per-frame entry point ------------------------------------------------------------------
# Call once per rendered frame with the same RGB buffer you pass to SDL_UpdateTexture. `stamp` is a
# host timestamp (e.g. SDL_GetTicks() ms), `keymask` is a host-defined bitfield of held keys (low 8
# bits shown as the on-panel strip), and `label` is a short host-formatted key list for the CSV
# (avoid commas; join with '+').
def comic_capture_rgb(c: mutable ComicCapture&, pixels: u32&, src_w: i32, src_h: i32,
                      stamp: i32, keymask: u32, label: cstr) -> void:
    requires src_w >= 1
    requires src_h >= 1
    c.tick <- c.tick + 1
    if c.tick < c.interval:
        return
    c.tick <- 0
    if c.panel_idx == 0:
        cc_fill_page(c, 28u8, 28u8, 38u8)     # dark gutter background for a fresh page
    cc_blit_panel(c, pixels, src_w, src_h, c.panel_idx)
    cc_burn_annot(c, c.panel_idx, stamp, keymask)
    cc_meta_row(c, stamp, keymask, label)     # uses the same seq/panel the panel was burned with
    c.seq <- c.seq + 1
    c.panel_idx <- c.panel_idx + 1
    if c.panel_idx >= c.cols * c.rows:
        cc_write_png(c)
        c.page_idx <- c.page_idx + 1
        c.panel_idx <- 0

# Flush a partially-filled page (call on shutdown so trailing frames aren't lost).
def comic_flush(c: mutable ComicCapture&) -> void:
    if c.panel_idx > 0:
        cc_write_png(c)
        c.page_idx <- c.page_idx + 1
        c.panel_idx <- 0
    if c.meta_f != null:
        _ = fclose(c.meta_f)
        c.meta_f <- null
