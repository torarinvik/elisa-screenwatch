# vidingest.elisa — video-file frame source for the orchestra (orchestra_v3_plan.md V0).
#
# A video file becomes indistinguishable from a live capture session: the SAME delta-encoded batch
# format, the SAME Tier-A archive, consumed by the SAME tracker/triage/OCR/VLM members. Only the
# FRAME SOURCE changes — instead of ScreenCaptureKit (frame_dump) or a scripted scene (scenegen),
# pixels come from ffmpeg decoding the video. There is exactly one encoder (encoder.elisa); this is
# just a third front-end that fills SCREEN_GRAB, same as its siblings.
#
# Time is synthetic and segment-relative: frame f is stamped t_ms = f * (1000/fps), independent of
# wall clock, so ingesting the same segment twice is BIT-IDENTICAL (H.264 decode is deterministic
# for a fixed ffmpeg build; the batch/archive writers are pure). --t0/--dur cut a segment; gold
# timestamps stay segment-relative (0-based) and the manifest records the video offset.
#
# ffprobe reports the source WxH; ffmpeg is asked to emit rawvideo bgra at that resolution (capped
# to SRC_CAP_W to bound cost), which on a little-endian host lands in SCREEN_GRAB as 0x00RRGGBB
# words (the alpha byte sits in the high bits and is masked off by downscale_into/archive_frame) —
# exactly the format the live grabber produces.
#
# USAGE: vidingest <video> [out_dir] [--fps 10] [--width 192] [--t0 <s>] [--dur <s>]
#   video     path to the source video file (required)
#   out_dir   batch/archive directory                 (default /tmp/vidingest_out)
#   --fps     resample rate fed to the encoder         (default 10; max 60)
#   --width   downscaled grid width                    (default 192; max 256)
#   --t0      segment start offset, seconds            (default 0 = whole video)
#   --dur     segment duration, seconds                (default 0 = to end)

include "./encoder.elisa"

extern popen(cmd: u8&, mode: u8&) -> heap void&?
extern pclose(stream: void&) -> int
extern fread(ptr: u8&, size: usize, nmemb: usize, stream: void&) -> usize

global mutable VI_CMD: array[u8, 8192] = zeroed      # ffprobe/ffmpeg command staging
global mutable VI_OUT: array[u8, 256] = zeroed       # ffprobe stdout staging
global mutable g_iw: i32 = 0                          # probed source width
global mutable g_ih: i32 = 0                          # probed source height

global SRC_CAP_W: i32 = 1280                          # cap decoded width (bounds downscale/archive cost)

# ---- small helpers -----------------------------------------------------------------------------

def vi_streq(a: u8&, b: cstr) -> bool:
    i: mutable i32 = 0
    while a[i.usize()] != 0 and b[i.usize()] != 0:
        false return if a[i.usize()] != b[i.usize()]
        i <- i + 1
    return a[i.usize()] == b[i.usize()]

def is_digit(b: u8) -> bool:
    v: i32 = b.i32()
    return v >= 48 and v <= 57

# argv scan: the int after a named flag, or `dflt` when the flag is absent.
def flag_i32(argc: int, argv: u8&&, name: cstr, dflt: i32) -> i32:
    requires argc >= 0
    i: mutable int = 1
    while i < argc:
        if vi_streq(argv[i], name):
            return atoi(argv[i + 1]).i32() if i + 1 < argc else dflt
        i <- i + 1
    return dflt

# parse the first two decimal integers out of a NUL-terminated buffer into g_iw,g_ih.
def parse_two(s: u8&) -> bool:
    i: mutable i32 = 0
    while s[i.usize()] != 0 and not is_digit(s[i.usize()]):
        i <- i + 1
    a: mutable i32 = 0
    while is_digit(s[i.usize()]):
        a <- a * 10 + (s[i.usize()].i32() - 48)
        i <- i + 1
    while s[i.usize()] != 0 and not is_digit(s[i.usize()]):
        i <- i + 1
    b: mutable i32 = 0
    while is_digit(s[i.usize()]):
        b <- b * 10 + (s[i.usize()].i32() - 48)
        i <- i + 1
    g_iw <- a
    g_ih <- b
    return a > 0 and b > 0

# ffprobe the first video stream's width,height into g_iw,g_ih.
def probe_dims(video: cstr) -> bool:
    off: mutable i32 = 0
    off <- u8buf_set_str(&VI_CMD[0], off, "ffprobe -v error -select_streams v:0 -show_entries stream=width,height -of csv=p=0 '")
    off <- u8buf_set_str(&VI_CMD[0], off, video)
    off <- u8buf_set_str(&VI_CMD[0], off, "'")
    VI_CMD[off.usize()] <- 0
    p: void&? = popen(&VI_CMD[0], "r".cast[u8&])
    if p is fp:
        n: usize = fread(&VI_OUT[0], 1.usize(), 255.usize(), fp)
        _ = pclose(fp)
        VI_OUT[n.i32().usize()] <- 0
        return parse_two(&VI_OUT[0])
    return false

# Build: ffmpeg -nostdin -hide_banner -loglevel error -i '<v>' [-ss t0] [-t dur]
#        -vf scale=ow:oh,fps=<fps> -pix_fmt bgra -f rawvideo -
def build_ffmpeg_cmd(video: cstr, t0: i32, dur: i32, ow: i32, oh: i32, fps: i32) -> void:
    requires ow >= 1 and oh >= 1 and fps >= 0
    off: mutable i32 = 0
    off <- u8buf_set_str(&VI_CMD[0], off, "ffmpeg -nostdin -hide_banner -loglevel error -i '")
    off <- u8buf_set_str(&VI_CMD[0], off, video)
    off <- u8buf_set_str(&VI_CMD[0], off, "'")
    if t0 > 0:
        off <- u8buf_set_str(&VI_CMD[0], off, " -ss ")
        off <- u8buf_set_num(&VI_CMD[0], off, t0.i64())
    if dur > 0:
        off <- u8buf_set_str(&VI_CMD[0], off, " -t ")
        off <- u8buf_set_num(&VI_CMD[0], off, dur.i64())
    off <- u8buf_set_str(&VI_CMD[0], off, " -vf scale=")
    off <- u8buf_set_num(&VI_CMD[0], off, ow.i64())
    off <- u8buf_set_str(&VI_CMD[0], off, ":")
    off <- u8buf_set_num(&VI_CMD[0], off, oh.i64())
    off <- u8buf_set_str(&VI_CMD[0], off, ",fps=")
    off <- u8buf_set_num(&VI_CMD[0], off, fps.i64())
    off <- u8buf_set_str(&VI_CMD[0], off, " -pix_fmt bgra -f rawvideo -")
    VI_CMD[off.usize()] <- 0

# Read exactly nbytes into dst, looping over short pipe reads. False at clean EOF / torn tail.
def read_full(dst: u8&, nbytes: i32, stream: void&) -> bool:
    got: mutable i32 = 0
    while got < nbytes:
        r: usize = fread(&dst[got.usize()], 1.usize(), (nbytes - got).usize(), stream)
        false return if r == 0.usize()
        got <- got + r.i32()
    return true

# ---- driver ------------------------------------------------------------------------------------

def main(argc: int, argv: u8&&) -> int:
    requires argc >= 0
    if argc < 2:
        _ = printf("usage: vidingest <video> [out_dir] [--fps 10] [--width 192] [--t0 <s>] [--dur <s>]\n".cast[u8&])
        return 2
    video: cstr = argv[1].cast[cstr]
    # out_dir is positional arg 2 unless it looks like a flag
    has_dir: bool = argc >= 3 and argv[2][0.usize()] != 45
    dir: cstr = argv[2].cast[cstr] if has_dir else "/tmp/vidingest_out"

    fps: i32 = clamp_i32(flag_i32(argc, argv, "--fps", 10), 1, 60)
    out_w: i32 = clamp_i32(flag_i32(argc, argv, "--width", 192), 8, MAX_OUT_W)
    t0: i32 = at_least(flag_i32(argc, argv, "--t0", 0), 0)
    dur: i32 = at_least(flag_i32(argc, argv, "--dur", 0), 0)

    if not probe_dims(video):
        _ = printf("vidingest: ffprobe failed (is ffmpeg installed? is the path correct?)\n".cast[u8&])
        return 1

    # decoded source resolution (capped to bound cost); ffmpeg scales to exactly ow x oh
    ow: i32 = g_iw if g_iw <= SRC_CAP_W else SRC_CAP_W
    oh: i32 = g_ih if g_iw <= SRC_CAP_W else at_least(g_ih * SRC_CAP_W / g_iw, 1)
    if ow < 1 or oh < 1 or ow * oh > GRAB_CAP:
        _ = printf("vidingest: bad or too-large source resolution\n".cast[u8&])
        return 1
    frame_bytes: i32 = ow * oh * 4

    _ = mkdir(dir.cast[u8&], 493)                     # 0o755; ignore EEXIST
    build_named_path(&LATEST_PATH[0], &LATEST_TMP[0], dir, "latest.txt")

    out_h0: i32 = clamp_i32(out_w * oh / ow, 8, 256)
    out_h: i32 = RING_STRIDE / out_w if out_w * out_h0 > RING_STRIDE else out_h0

    token_cap: i32 = 40000
    cap_bytes: i32 = token_cap * 4
    retain: i32 = 100000                              # eval keeps the whole run
    batch_frames: i32 = fps * 2 if fps * 2 <= MAX_BATCH_FRAMES else MAX_BATCH_FRAMES
    frame_interval_ms: i64 = (1000 / fps).i64()

    assert(fps >= 1)                                   # clamp_i32(.., 1, 60) guarantees this
    build_ffmpeg_cmd(video, t0, dur, ow, oh, fps)
    src: void&? = popen(&VI_CMD[0], "r".cast[u8&])
    if src is fp:
        archive_init(dir, 2048)
        _ = printf("vidingest: decoding video -> batches (deterministic, segment-relative time).\n".cast[u8&])
        batch: mutable i64 = 0
        f: mutable i64 = 0
        eof: mutable bool = false
        while not eof:
            i: mutable i32 = 0
            while i < batch_frames and not eof:
                ok: mutable bool = false
                trusted Unsafe.PointerCast:
                    ok <- read_full((&SCREEN_GRAB[0]).cast[u8&], frame_bytes, fp)
                eof <- true if not ok
                if ok:
                    t_ms: i64 = f * frame_interval_ms
                    archive_frame(&SCREEN_GRAB[0], ow, oh, t_ms)
                    downscale_into(&SCREEN_GRAB[0], ow, oh, out_w, out_h, i * RING_STRIDE)
                    write_frame_ppm(dir, batch, ow, oh) if i == 0
                    FRAME_MS[i.usize()] <- t_ms
                    i <- i + 1
                    f <- f + 1
            if i > 0:
                _ = write_batch_dir(dir, batch, i, out_w, out_h, fps, cap_bytes, retain, token_cap, 1)
                batch <- batch + 1
        _ = pclose(fp)
        archive_stop()
        _ = printf("vidingest: done.\n".cast[u8&])
        return 0
    _ = printf("vidingest: could not launch ffmpeg\n".cast[u8&])
    return 1
