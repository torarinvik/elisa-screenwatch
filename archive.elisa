# archive.elisa — Tier A exact-frame ring (SPEC.md "Archive").
#
# Bit-exact archival of every grabbed full-res frame, bounded by a byte budget. Each frame is
# XORed against the previous frame's pixel words and LZFSE-compressed (screen deltas are mostly
# zero words, so calm screens cost ~KBs/frame). Segments of AR_SEG_FRAMES frames start with a
# compressed KEYFRAME so every segment decodes independently; the oldest segments are pruned when
# the ring exceeds its byte cap.
#
# Files (in the batch directory, single writer, append-only):
#   arch_<seg>.bin   payload stream: per frame one compressed (or raw-fallback) blob
#   arch_<seg>.idx   text index, one line per frame:
#                    <seq> <t_ms> <kind> <len> <w> <h> <hash>
#                    kind: 0=keyframe lzfse  1=delta lzfse  2=keyframe raw  3=delta raw
#
# EXACTNESS IS A TESTED PROPERTY: <hash> is a position-dependent 64-bit checksum of the RAW frame
# words (rotate-xor — no wrapping arithmetic). `arch_tool verify` re-decodes every frame and
# recomputes it; any bit difference fails. Timestamps t_ms are the same CLOCK_MONOTONIC-derived
# recorder timeline the batches use (ms since recorder start).
#
# Host must provide externs: fopen, fwrite, fclose, remove (frame_dump/arch_tool both do).
# Link with -lcompression (Apple libcompression, LZFSE).

extern compression_encode_buffer(dst: u8&, dstcap: usize, src: u8&, srclen: usize, scratch: void&?, algo: int) -> usize
extern compression_decode_buffer(dst: u8&, dstcap: usize, src: u8&, srclen: usize, scratch: void&?, algo: int) -> usize

const AR_LZFSE: int = 2049                      # COMPRESSION_LZFSE = 0x801
const AR_CAP_PX: i32 = 24000000                 # matches SCREEN_GRAB capacity
global AR_SEG_FRAMES: i64 = 240                 # ~10s per segment at 24fps
global AR_SEG_RING: i64 = 8192                  # max live segments tracked for pruning

global mutable AR_PREV: array[u32, 24000000] = zeroed    # previous frame's words (encode chain)
global mutable AR_XOR: array[u32, 24000000] = zeroed     # xor scratch (encode) / decode accumulator
global mutable AR_ENC: array[u8, 100000000] = zeroed     # compressed payload scratch

global mutable ar_dir: cstr = ""
global mutable ar_cap_bytes: i64 = 0            # ring byte budget; 0 = archive disabled
global mutable ar_seq: i64 = 0                  # frames archived (global, == idx seq field)
global mutable ar_seg: i64 = 0                  # current segment number
global mutable ar_seg_lo: i64 = 0               # oldest live segment
global mutable ar_in_seg: i64 = 0               # frames in the current segment
global mutable ar_bin: void&? = null
global mutable ar_idx: void&? = null
global mutable ar_total: i64 = 0                # live ring bytes (payload+index approx)
global mutable ar_prev_w: i32 = 0
global mutable ar_prev_h: i32 = 0
global mutable AR_SEG_BYTES: array[i64, 8192] = zeroed
global mutable AR_PATH: array[u8, 1024] = zeroed
global mutable AR_LINE: array[u8, 256] = zeroed

# ---- tiny self-contained text helpers (archive is include-order independent) -------------------
def ar_put_str(dst: mutable u8&, off0: i32, s: cstr) -> i32:
    off: mutable i32 = off0
    i: mutable i32 = 0
    while s[i.usize()] != 0:
        dst[off.usize()] <- s[i.usize()]
        off <- off + 1
        i <- i + 1
    return off

def ar_put_num(dst: mutable u8&, off0: i32, v0: i64) -> i32:
    off: mutable i32 = off0
    v: mutable i64 = v0
    tmp: mutable array[u8, 24] = zeroed
    n: mutable i32 = 0
    while v > 0:
        tmp[n.usize()] <- (48 + (v % 10).i32()).u8()
        v <- v / 10
        n <- n + 1
    dst[off.usize()] <- 48 if n == 0
    off <- off + 1 if n == 0
    while n > 0:
        n <- n - 1
        dst[off.usize()] <- tmp[n.usize()]
        off <- off + 1
    return off

# path = <dir>/arch_<seg>.<ext>
def ar_path(dir: cstr, seg: i64, ext: cstr) -> void:
    off: mutable i32 = 0
    off <- ar_put_str(&AR_PATH[0], off, dir)
    off <- ar_put_str(&AR_PATH[0], off, "/arch_")
    off <- ar_put_num(&AR_PATH[0], off, seg)
    off <- ar_put_str(&AR_PATH[0], off, ext)
    AR_PATH[off.usize()] <- 0

# ---- checksum: position-dependent rotate-xor over the frame words (no wrapping arithmetic) -----
def ar_hash(px: u32&, n: i32) -> u64:
    h: mutable u64 = 1469598103934665603
    i: mutable i32 = 0
    while i < n:
        h <- ((h << 7) | (h >> 57)) ^ px[i.usize()].u64()
        i <- i + 1
    return h

# ---- writer ------------------------------------------------------------------------------------
def archive_init(dir: cstr, cap_mb: i32) -> void:
    ar_dir <- dir
    ar_cap_bytes <- cap_mb.i64() * 1000000

def ar_close_seg() -> void:
    if ar_bin is b:
        _ = fclose(b)
        ar_bin <- null
    if ar_idx is x:
        _ = fclose(x)
        ar_idx <- null

def ar_prune() -> void:
    while ar_total > ar_cap_bytes and ar_seg_lo < ar_seg:
        old: i64 = ar_seg_lo
        ar_path(ar_dir, old, ".bin")
        _ = remove(&AR_PATH[0])
        ar_path(ar_dir, old, ".idx")
        _ = remove(&AR_PATH[0])
        ar_total <- ar_total - AR_SEG_BYTES[(old % AR_SEG_RING).usize()]
        AR_SEG_BYTES[(old % AR_SEG_RING).usize()] <- 0
        ar_seg_lo <- ar_seg_lo + 1

def ar_open_seg() -> void:
    ar_close_seg()
    ar_path(ar_dir, ar_seg, ".bin")
    ar_bin <- fopen(&AR_PATH[0], "wb".cast[u8&])
    ar_path(ar_dir, ar_seg, ".idx")
    ar_idx <- fopen(&AR_PATH[0], "wb".cast[u8&])
    ar_in_seg <- 0
    AR_SEG_BYTES[(ar_seg % AR_SEG_RING).usize()] <- 0

# Archive one grabbed frame (0x00RRGGBB words, w x h). t_ms = recorder-timeline milliseconds.
def archive_frame(px: u32&, w: i32, h: i32, t_ms: i64) -> void:
    return if ar_cap_bytes == 0
    return if w < 1 or h < 1 or w * h > AR_CAP_PX
    n: i32 = w * h
    bytes: usize = (n * 4).usize()

    # rotate to a fresh segment on schedule or on a resolution change (keyframe realigns the chain)
    key: bool = ar_in_seg == 0 or ar_in_seg >= AR_SEG_FRAMES or w != ar_prev_w or h != ar_prev_h
    if key:
        ar_seg <- ar_seg + 1 if ar_in_seg > 0
        ar_open_seg()
    bf0: void&? = ar_bin
    xf0: void&? = ar_idx

    # payload source: the raw frame (keyframe) or the xor delta vs the previous frame
    if key:
        i: mutable i32 = 0
        while i < n:
            AR_XOR[i.usize()] <- px[i.usize()]
            i <- i + 1
    else:
        i: mutable i32 = 0
        while i < n:
            AR_XOR[i.usize()] <- px[i.usize()] ^ AR_PREV[i.usize()]
            i <- i + 1

    enc: mutable usize = 0
    trusted Unsafe.PointerCast:
        enc <- compression_encode_buffer(&AR_ENC[0], bytes, (&AR_XOR[0]).cast[u8&], bytes, null, AR_LZFSE)
    kind: mutable i64 = 0 if key else 1
    plen: mutable usize = enc
    if enc == 0.usize():                     # incompressible: store the raw payload (still exact)
        kind <- kind + 2
        plen <- bytes

    if bf0 is bf:
        if kind >= 2:
            trusted Unsafe.PointerCast:
                _ = fwrite((&AR_XOR[0]).cast[u8&], 1.usize(), plen, bf)
        else:
            _ = fwrite(&AR_ENC[0], 1.usize(), plen, bf)

    # index line: <seq> <t_ms> <kind> <len> <w> <h> <hash>
    hsh: u64 = ar_hash(px, n)
    off: mutable i32 = 0
    off <- ar_put_num(&AR_LINE[0], off, ar_seq)
    off <- ar_put_str(&AR_LINE[0], off, " ")
    off <- ar_put_num(&AR_LINE[0], off, t_ms)
    off <- ar_put_str(&AR_LINE[0], off, " ")
    off <- ar_put_num(&AR_LINE[0], off, kind)
    off <- ar_put_str(&AR_LINE[0], off, " ")
    off <- ar_put_num(&AR_LINE[0], off, plen.i64())
    off <- ar_put_str(&AR_LINE[0], off, " ")
    off <- ar_put_num(&AR_LINE[0], off, w.i64())
    off <- ar_put_str(&AR_LINE[0], off, " ")
    off <- ar_put_num(&AR_LINE[0], off, h.i64())
    off <- ar_put_str(&AR_LINE[0], off, " ")
    # the checksum prints as two u32 halves to stay in i64-safe decimal printing
    off <- ar_put_num(&AR_LINE[0], off, (hsh >> 32).i64())
    off <- ar_put_str(&AR_LINE[0], off, ":")
    off <- ar_put_num(&AR_LINE[0], off, (hsh & 4294967295).i64())
    AR_LINE[off.usize()] <- 10
    if xf0 is xf:
        _ = fwrite(&AR_LINE[0], 1.usize(), (off + 1).usize(), xf)

    # advance the chain + ring accounting
    i2: mutable i32 = 0
    while i2 < n:
        AR_PREV[i2.usize()] <- px[i2.usize()]
        i2 <- i2 + 1
    ar_prev_w <- w
    ar_prev_h <- h
    grew: i64 = plen.i64() + (off + 1).i64()
    AR_SEG_BYTES[(ar_seg % AR_SEG_RING).usize()] <- AR_SEG_BYTES[(ar_seg % AR_SEG_RING).usize()] + grew
    ar_total <- ar_total + grew
    ar_in_seg <- ar_in_seg + 1
    ar_seq <- ar_seq + 1
    ar_prune()

def archive_stop() -> void:
    ar_close_seg()
