# scenegen.elisa — deterministic synthetic scene source for the eval battery (eval/scenarios.md).
#
# Renders a scripted scene into SCREEN_GRAB and drives the SAME real encoder as the live recorder
# (encoder.elisa), so a fixture is byte-for-byte the stream + Tier-A archive a watcher sees in
# production — but reproducible, timing-exact, and with no screen-recording permission. This is how
# the CONTROLLED scenarios (counter, brief object, occlusion, invisible-event) get produced with
# exact ground truth; a real app can't hit the timing.
#
# Time is synthetic: frame f is stamped t_ms = f * (1000/fps), independent of wall clock, so two
# runs of the same scene are identical. Scene timings here MUST match the authored ground truth in
# eval/scenarios/<name>/{truth,probes}.jsonl.
#
# USAGE: scenegen <scene> [out_dir] [width] [fps] [dur_ms] [--seed N] [--final]
#   scene    counter, counter-skip, motion, motion-trap, crossing-swap, occlude-vanish,
#            scroll-motion, contact-merge
#   out_dir  fixture directory                       (default /tmp/scenegen_out)
#   width    downscaled grid width                   (default 192)
#   fps      frames per second                       (default 10)
#   dur_ms   total scene duration in ms              (default 20000)
#   --seed N SEEDED PROCEDURAL MODE (V1.5): positions, sizes, lanes, event times and (where safe)
#            direction all derive from N via xorshift64, and scenegen emits its own truth.jsonl +
#            probes.jsonl computed from the same parameters — the generator is its own annotator,
#            so a tracker cannot score by memorizing the fixed scenes. Without --seed the output is
#            bit-identical to the historical fixed scenes (authored gold stays valid).
#   --final  required to run RESERVED seeds (>= 1000): those are held out for final milestone
#            scoring only and must never be run during development (orchestra_v3_plan.md V1.5).

include "./encoder.elisa"

# synthetic source resolution (fits GRAB_CAP; big enough for a legible grid at width 192)
global mutable SG_W: i32 = 640
global mutable SG_H: i32 = 400

# 5x7 bitmap font, digits 0-9, row-major (10*7 rows); low 5 bits per row, bit4 = leftmost column.
global mutable FONT: array[u8, 70] = [
    14, 17, 19, 21, 25, 17, 14,     # 0
     4, 12,  4,  4,  4,  4, 14,     # 1
    14, 17,  1,  2,  4,  8, 31,     # 2
    31,  2,  4,  2,  1, 17, 14,     # 3
     2,  6, 10, 18, 31,  2,  2,     # 4
    31, 16, 30,  1,  1, 17, 14,     # 5
     6,  8, 16, 30, 17, 17, 14,     # 6
    31,  1,  2,  4,  8,  8,  8,     # 7
    14, 17, 17, 14, 17, 17, 14,     # 8
    14, 17, 17, 15,  1,  2, 12,     # 9
]

def sg_streq(a: u8&, b: cstr) -> bool:
    i: mutable i32 = 0
    while a[i.usize()] != 0 and b[i.usize()] != 0:
        false return if a[i.usize()] != b[i.usize()]
        i <- i + 1
    return a[i.usize()] == b[i.usize()]

def fill_bg(color: u32) -> void:
    n: i32 = SG_W * SG_H
    i: mutable i32 = 0
    while i < n:
        SCREEN_GRAB[i.usize()] <- color
        i <- i + 1

def fill_rect(x: i32, y: i32, w: i32, h: i32, color: u32) -> void:
    yy: mutable i32 = y
    while yy < y + h:
        if yy >= 0 and yy < SG_H:
            xx: mutable i32 = x
            while xx < x + w:
                SCREEN_GRAB[(yy * SG_W + xx).usize()] <- color if xx >= 0 and xx < SG_W
                xx <- xx + 1
        yy <- yy + 1

# Draw one glyph (digit 0-9) with its top-left at (cx,cy), each font pixel a scale x scale block.
def draw_digit(cx: i32, cy: i32, scale: i32, d: i32, fg: u32) -> void:
    return if d < 0 or d > 9
    base: i32 = d * 7
    row: mutable i32 = 0
    while row < 7:
        bits: u8 = FONT[(base + row).usize()]
        col: mutable i32 = 0
        while col < 5:
            on: bool = ((bits >> (4 - col).u8()) & 1) == 1
            fill_rect(cx + col * scale, cy + row * scale, scale, scale, fg) if on
            col <- col + 1
        row <- row + 1

# ---- scenes ------------------------------------------------------------------------------------

# The trap sequence for counter-skip: NOT monotonic (positions 3 and 7 are swapped). A watcher that
# infers "digit = batch index" instead of READING the grid answers wrong exactly at batches 3 and 7.
global mutable SEQ_SKIP: array[u8, 10] = [0, 1, 2, 7, 4, 5, 6, 3, 8, 9]

# ---- seeded procedural mode (V1.5): parameters derive from --seed via xorshift64 ----------------
#
# Without --seed every parameter below holds its historical constant, so the fixed scenes stay
# BIT-IDENTICAL and the authored gold in eval/scenarios/ remains valid. With --seed N, positions,
# sizes, lanes and event times randomize within construction-safe ranges (each range is chosen so
# the scene's defining property survives: a mid-field reversal stays in the middle zone, an
# occlusion stays between the tracker's LOST/OCC thresholds, squares stay on screen), and
# emit_gold() writes truth.jsonl + probes.jsonl computed from the SAME parameters — the generator
# annotates its own fixture, so a tracker cannot score by memorizing the seven fixed scenes.
# Seeds >= RESERVED_SEED are held out for final scoring and refuse to run without --final.

global RESERVED_SEED: i64 = 1000
global mutable SG_SEED: i64 = -1              # -1 = unseeded (historical fixed scenes)
global mutable RNG_S: u64 = 1

# V1.2 metamorphic variants: same seed, frames bit-identical up to the divergence moment, exactly
# ONE property changed. Pair scoring (eval/meta_test.sh) credits a probe only when the answer is
# correct on BOTH sides of the pair — a prior-driven answer that ignores the pixels scores 0.
global mutable VAR_NV: i32 = 0                # no-vanish: motion-trap gap becomes a visible glide
global mutable VAR_NR: i32 = 0                # no-reverse: hold at the reversal point instead
global mutable VAR_EL: i32 = 0                # early-launch: launch scene, B departs BEFORE contact
global mutable PHASE_MS: i32 = 0              # V1.7: sub-batch shift of all param-derived event times
global mutable SK_I: i32 = 3                  # counter-skip: the two swapped positions
global mutable SK_J: i32 = 7

# xorshift64 — shift/xor only (no wrapping arithmetic), deterministic per seed.
def rng_next() -> u64:
    x: mutable u64 = RNG_S
    x <- x ^ (x << 13)
    x <- x ^ (x >> 7)
    x <- x ^ (x << 17)
    RNG_S <- x
    return x

# uniform int in [lo, hi] (inclusive). The final clamp is dead at runtime (mod keeps the value in
# range) but makes the ensure structurally provable, so call sites inherit the bounds.
def rnd(lo: i32, hi: i32) -> i32:
    requires hi >= lo
    ensure result >= lo
    ensure result <= hi
    span: u64 = (hi - lo + 1).i64().u64()
    r: i32 = lo + (rng_next() % span).i64().i32()
    return lo if r < lo else (hi if r > hi else r)

# motion: X0 -> X1, bounce at TB, back; MIR mirrors the whole trajectory horizontally
global mutable MO_X0: i32 = 40
global mutable MO_X1: i32 = 540
global mutable MO_TB: i32 = 10000
global mutable MO_Y: i32 = 170
global mutable MO_MIR: i32 = 0

# motion-trap: X0 -> XV (vanish at T0), gone until T1, XR0 -> XR1 (reverse at TR), back to XE
global mutable MT_X0: i32 = 40
global mutable MT_XV: i32 = 430
global mutable MT_T0: i32 = 8000
global mutable MT_T1: i32 = 10000
global mutable MT_XR0: i32 = 300
global mutable MT_XR1: i32 = 420
global mutable MT_TR: i32 = 14000
global mutable MT_XE: i32 = 40
global mutable MT_Y: i32 = 170
global mutable MT_MIR: i32 = 0

# crossing-swap: A left->right, B right->left, lanes YC -/+ OFF
global mutable CS_X0: i32 = 40
global mutable CS_X1: i32 = 540
global mutable CS_OFF: i32 = 6
global mutable CS_YC: i32 = 170

# occlude-vanish: B vanishes for good at TBV (40 -> BXV); static block at BLX, width BLW
global mutable OV_TBV: i32 = 8000
global mutable OV_BXV: i32 = 440
global mutable OV_BLX: i32 = 250
global mutable OV_BLW: i32 = 120

# scroll-motion: stripes shift PX px over [T0, T0+LEN]; square X0 -> X0+DX independently
global mutable SM_T0: i32 = 5000
global mutable SM_LEN: i32 = 5000
global mutable SM_PX: i32 = 120
global mutable SM_X0: i32 = 60
global mutable SM_DX: i32 = 460

# contact-merge: approach depth D (meet at t=10s), lane Y
global mutable CM_D: i32 = 230
global mutable CM_Y: i32 = 170

# launch (V1.3b relation probe): A approaches static B and "launches" it at contact (base) —
# or B departs EL ms BEFORE contact (--variant early-launch: effect precedes cause). Lanes are
# OFF px apart so bboxes overlap by OL px at contact without sharing grid cells (crossing-swap
# geometry). TC = contact time.
global mutable LA_Y: i32 = 170
global mutable LA_OFF: i32 = 8
global mutable LA_BX: i32 = 430
global mutable LA_OL: i32 = 10
global mutable LA_TC: i32 = 10000
global mutable LA_EL: i32 = 2000

# Derive the active scene's parameters from the seed (no-op when unseeded). Ranges are documented
# against the constraint they protect.
def setup_scene_params(scene_id: i32, seed: i64) -> void:
    SG_SEED <- seed
    # lane defaults depend on SQ; recompute so unseeded matches the historical mid-height lane
    MO_Y <- SG_H / 2 - SQ / 2
    MT_Y <- SG_H / 2 - SQ / 2
    CS_YC <- SG_H / 2 - SQ / 2
    CM_Y <- SG_H / 2 - SQ / 2
    LA_Y <- SG_H / 2 - SQ / 2
    return if seed < 0
    RNG_S <- (seed + 1).u64()             # nonzero state; distinct seeds -> distinct streams
    w: mutable i32 = 0
    while w < 12:                         # warm the stream past the low-entropy start
        _ = rng_next()
        w <- w + 1
    if scene_id == 1:
        # counter-skip: swap two random positions in 1..8 (0 and 9 stay, so the count still
        # starts at 0 and ends at 9 — the trap is WHERE the monotonic pattern breaks)
        k: mutable i32 = 0
        while k < 10:
            SEQ_SKIP[k.usize()] <- k.u8()
            k <- k + 1
        i: i32 = rnd(1, 8)
        j0: i32 = rnd(1, 7)
        j: i32 = j0 + 1 if j0 >= i else j0    # j != i, uniform over the remaining 7 slots
        tmp: u8 = SEQ_SKIP[i.usize()]
        SEQ_SKIP[i.usize()] <- SEQ_SKIP[j.usize()]
        SEQ_SKIP[j.usize()] <- tmp
        SK_I <- i
        SK_J <- j
    # ranges derive through LOCALS (immutable bindings keep their rnd-ensure bounds across the
    # rng_next() calls that invalidate global facts), then land in the param globals
    if scene_id == 2:
        sq2: i32 = rnd(44, 72)
        SQ <- sq2
        MO_Y <- rnd(60, 340 - sq2)
        MO_X0 <- rnd(30, 80)
        MO_X1 <- SG_W - sq2 - rnd(30, 80)     # bounce center stays > 0.75*W (zone "right")
        MO_TB <- rnd(8000, 12000)
        MO_MIR <- rnd(0, 1)
    if scene_id == 3:
        sq3: i32 = rnd(44, 72)
        SQ <- sq3
        MT_Y <- rnd(60, 340 - sq3)
        MT_X0 <- rnd(30, 80)
        t0: i32 = rnd(6000, 9000)
        t1: i32 = t0 + rnd(1600, 2400)        # gap comfortably inside the vanish-detect window
        MT_T0 <- t0
        MT_T1 <- t1
        MT_TR <- t1 + rnd(2600, 4500)         # reversal well after reacquire, well before end
        xr0: i32 = rnd(200, 300)
        MT_XR0 <- xr0
        MT_XR1 <- xr0 + rnd(70, 115)          # reversal center stays in (0.25, 0.75)*W: "middle"
        MT_XV <- xr0 + rnd(90, 170)           # reappears DISPLACED (behind the vanish point)
        MT_XE <- rnd(30, 70)
        MT_MIR <- rnd(0, 1)
    if scene_id == 4:
        sq4: i32 = rnd(44, 72)
        SQ <- sq4
        CS_OFF <- rnd(5, 10)
        CS_YC <- rnd(70, 330 - sq4)
        CS_X0 <- rnd(30, 70)
        CS_X1 <- SG_W - sq4 - rnd(30, 70)
    if scene_id == 5:
        sq5: i32 = rnd(48, 64)                # block y-span 20..160 must fully cover A's lane
        SQ <- sq5
        blw: i32 = sq5 + rnd(56, 68)          # full-hide = (BLW-SQ)/26px_s ~ 2.1..2.6s (> LOST_MAX, < OCC_MAX)
        OV_BLW <- blw
        OV_BLX <- rnd(220, 470 - blw)         # A fully re-emerges with >= 2s of visible tail
        OV_TBV <- rnd(6000, 9500)
        OV_BXV <- rnd(380, 470)
    if scene_id == 6:
        sq6: i32 = rnd(44, 72)
        SQ <- sq6
        SM_T0 <- rnd(4000, 6000)
        SM_LEN <- rnd(4000, 6000)
        SM_PX <- rnd(90, 150)
        x06: i32 = rnd(40, 90)
        SM_X0 <- x06
        SM_DX <- rnd(380, 630 - x06 - sq6)    # square stays on screen throughout
    if scene_id == 7:
        sq7: i32 = rnd(44, 72)
        SQ <- sq7
        ol: i32 = rnd(18, 42)                 # overlap depth at the meet
        CM_D <- (500 - sq7 + ol) / 2
        CM_Y <- rnd(60, 340 - sq7)
    if scene_id == 8:
        sq8: i32 = rnd(44, 72)
        SQ <- sq8
        LA_Y <- rnd(70, 320 - sq8)            # both lanes (Y±OFF) stay well inside the field
        LA_OFF <- rnd(5, 10)
        LA_BX <- rnd(380, 480)
        LA_OL <- rnd(6, 12)
        LA_TC <- rnd(8000, 11000)
        LA_EL <- rnd(1500, 2500)
    # V1.7 phase offset: shift every param-derived event time by PHASE ms (sub-batch, 0..1900) so
    # nothing aligns to 2 s batch boundaries by accident. Gold emission reads the same params, so
    # truth/probes shift with the frames automatically. Ranges above keep >= 2 s of headroom.
    if PHASE_MS > 0:
        MO_TB <- MO_TB + PHASE_MS
        MT_T0 <- MT_T0 + PHASE_MS
        MT_T1 <- MT_T1 + PHASE_MS
        MT_TR <- MT_TR + PHASE_MS
        OV_TBV <- OV_TBV + PHASE_MS
        SM_T0 <- SM_T0 + PHASE_MS
        LA_TC <- LA_TC + PHASE_MS

# t -> batch index (2s batches, clamped 0..9)
def batch_of(t_ms: i64) -> i32:
    b: mutable i32 = (t_ms / 2000).i32()
    b <- 9 if b > 9
    return b

# One centred large digit on a dark background (identical within a 2s phase -> SAME frames).
def draw_center_digit(d: i32) -> void:
    fill_bg(2105376)                      # 0x00202020 dark grey
    scale: i32 = 36
    cx: i32 = SG_W / 2 - (5 * scale) / 2
    cy: i32 = SG_H / 2 - (7 * scale) / 2
    draw_digit(cx, cy, scale, d, 15790320)    # 0x00F0F0F0 near-white

# counter: digit = batch index (a clean 0..9). Matches eval/scenarios/one-digit-counter.
def scene_counter(t_ms: i64) -> void:
    draw_center_digit(batch_of(t_ms))

# counter-skip: digit = SEQ_SKIP[batch] (the pattern breaks at batches 3 and 7). Matches
# eval/scenarios/counter-skip. This is the test of perceiving-vs-guessing.
def scene_counter_skip(t_ms: i64) -> void:
    draw_center_digit(SEQ_SKIP[batch_of(t_ms).usize()].i32())

# ---- motion scenes (the perceiving-vs-priors test for the VLM member, cursor_vlm_plan.md §4) ----

# A single bright square on the dark field, moving horizontally at mid-height. side px at source res.
global mutable SQ: i32 = 60

def draw_square(x: i32, color: u32) -> void:
    fill_rect(x, SG_H / 2 - SQ / 2, SQ, SQ, color)

# motion: honest continuous motion. x: X0 -> X1 (moving RIGHT), bounces at the edge at t=TB, then
# back (moving LEFT). One object, one edge-bounce, no surprises. MIR mirrors the whole trajectory.
# Unseeded (X0=40, X1=540, TB=10000, MIR=0) this is bit-identical to the historical scene.
def scene_motion(t_ms: i64) -> void:
    fill_bg(2105376)                                  # 0x00202020 dark
    x: mutable i64 = MO_X0.i64()
    if t_ms <= MO_TB.i64():
        x <- MO_X0.i64() + ((MO_X1 - MO_X0).i64() * t_ms) / MO_TB.i64()
    else:
        if VAR_NR == 1:
            x <- MO_X1.i64()                          # no-reverse: hold at the bounce point
        else:
            rem: i64 = 20000 - MO_TB.i64()
            tt: i64 = t_ms - MO_TB.i64()
            tt2: i64 = tt if tt < rem else rem
            x <- MO_X1.i64() - ((MO_X1 - MO_X0).i64() * tt2) / rem
    xm: i64 = (SG_W - SQ).i64() - x if MO_MIR == 1 else x
    fill_rect(xm.i32(), MO_Y, SQ, SQ, 15790320)       # 0x00F0F0F0 near-white

# motion-trap: priors-vs-pixels. Same square, but (a) it VANISHES mid-flight (t = T0..T1) and
# reappears DISPLACED (teleported back to XR0, behind where it vanished at XV); (b) at t=TR it
# reverses direction in MID-FIELD (nowhere near an edge). A continuity-prior model reports smooth
# motion and an edge-bounce; a perceiving one reports the vanish and the causeless reversal.
# Unseeded (T0=8000, T1=10000, TR=14000, X0=40, XV=430, XR0=300, XR1=420, XE=40) this is
# bit-identical to the historical scene.
def scene_motion_trap(t_ms: i64) -> void:
    fill_bg(2105376)
    visible: mutable bool = true
    x: mutable i64 = MT_X0.i64()
    if t_ms < MT_T0.i64():
        x <- MT_X0.i64() + ((MT_XV - MT_X0).i64() * t_ms) / MT_T0.i64()
    else:
        if t_ms < MT_T1.i64():
            if VAR_NV == 1:
                # no-vanish: visible glide between the SAME endpoints (XV -> XR0), so every frame
                # outside [T0,T1] is bit-identical to the base scene
                x <- MT_XV.i64() + ((MT_XR0 - MT_XV).i64() * (t_ms - MT_T0.i64())) / (MT_T1 - MT_T0).i64()
            else:
                visible <- false                      # VANISHED (dark field only)
        else:
            if t_ms < MT_TR.i64():
                x <- MT_XR0.i64() + ((MT_XR1 - MT_XR0).i64() * (t_ms - MT_T1.i64())) / (MT_TR - MT_T1).i64()
            else:
                if VAR_NR == 1:
                    x <- MT_XR1.i64()                 # no-reverse: hold at the reversal point
                else:
                    rem: i64 = 20000 - MT_TR.i64()
                    tt: i64 = t_ms - MT_TR.i64()
                    tt2: i64 = tt if tt < rem else rem
                    x <- MT_XR1.i64() - ((MT_XR1 - MT_XE).i64() * tt2) / rem
    xm: i64 = (SG_W - SQ).i64() - x if MT_MIR == 1 else x
    fill_rect(xm.i32(), MT_Y, SQ, SQ, 15790320) if visible

# ---- tracker (viola) trap scenes — exact-by-construction ground truth (orchestra_v2_plan.md M2) --

# Draw a square with its TOP-LEFT at (x,y) (motion scenes use a fixed mid-height row; these need
# independent vertical lanes so two objects can pass without their grids colliding).
def draw_square_at(x: i32, y: i32, color: u32) -> void:
    fill_rect(x, y, SQ, SQ, color)

# crossing-swap: two squares of identical size cross in X, on lanes 12px apart in Y so their bboxes
# overlap mid-crossing (t~9.5-10.5s) but never share a cell. A: left->right; B: right->left. Truth
# records which exits where; a CONFIDENT identity swap after the crossing scores worse than an honest
# UNKNOWN. Different fills (A brighter) so a perfect tracker COULD tell them apart — but the grid is
# luminance-only, so post-crossing identity is genuinely ambiguous.
def scene_crossing_swap(t_ms: i64) -> void:
    fill_bg(2105376)
    tt: i64 = t_ms if t_ms < 20000 else 20000
    ax: i64 = CS_X0.i64() + ((CS_X1 - CS_X0).i64() * tt) / 20000   # A: X0 -> X1 (right)
    bx: i64 = CS_X1.i64() - ((CS_X1 - CS_X0).i64() * tt) / 20000   # B: X1 -> X0 (left)
    ay: i32 = CS_YC - CS_OFF                           # A lane (upper)
    by: i32 = CS_YC + CS_OFF                           # B lane (lower)
    draw_square_at(ax.i32(), ay, 15790320)            # A near-white
    draw_square_at(bx.i32(), by, 10066329)            # B mid-grey 0x00999999

# occlude-vs-vanish: a static block mid-field. Square A (upper lane) moves right and passes BEHIND
# the block (drawn after A, so it hides A) for t~8-11s, then re-emerges. Square B (lower lane) moves
# right and genuinely VANISHES at t=8s, never returning. A must be REACQUIRED (occlusion), B must
# end as VANISH — the discrimination the tracker has to earn.
def scene_occlude_vanish(t_ms: i64) -> void:
    fill_bg(2105376)                                  # dominant dark background (clean mode)
    ay: i32 = 60                                      # A lane: y 60..120 (upper)
    by: i32 = 280                                     # B lane: y 280..340 (far lower, clear of block)
    tt: i64 = t_ms if t_ms < 20000 else 20000
    ax: i64 = 40 + (520 * tt) / 20000                 # A: 40 -> 560, steady right, constant velocity
    draw_square_at(ax.i32(), ay, 15790320)            # A
    if t_ms < OV_TBV.i64():
        bx: i64 = 40 + ((OV_BXV - 40).i64() * t_ms) / OV_TBV.i64()   # B: 40 -> BXV, then VANISHES for good
        draw_square_at(bx.i32(), by, 15790320)
    # static occluder: a tall, narrow grey block spanning A's lane in Y, drawn LAST so it hides A when
    # behind. A is fully behind while x in [BLX..BLX+BLW-SQ] -> (BLW-SQ)/26px_s of full hide, kept
    # > LOST_MAX and < OCC_MAX by setup_scene_params so REACQUIRE must win over a false VANISH. The
    # block is much larger than A so its centroid barely drags when A merges at the boundary (no
    # spurious REVERSE on a static object). Unseeded: x 250..370, y 20..160.
    fill_rect(OV_BLX, 20, OV_BLW, 140, 12303291)      # 0x00BBBBBB

# scroll-vs-motion: the whole background scrolls left (a striped field shifting 2px/frame-ish over
# t=5-10s) while one square moves right INDEPENDENTLY. The tracker's SHIFT-aware path must report the
# square's velocity in SCENE coords, not contaminated by the global scroll.
def scene_scroll_motion(t_ms: i64) -> void:
    # striped background whose phase shifts with time during the scroll window [T0, T0+LEN]
    shift: mutable i64 = 0
    if t_ms >= SM_T0.i64():
        st: i64 = t_ms - SM_T0.i64()
        st2: i64 = st if st < SM_LEN.i64() else SM_LEN.i64()
        shift <- (SM_PX.i64() * st2) / SM_LEN.i64()   # 0 -> PX px leftward over the window
    y: mutable i32 = 0
    while y < SG_H:
        x: mutable i32 = 0
        while x < SG_W:
            phase: i64 = (x.i64() + shift) / 40
            col: u32 = 3355443 if (phase % 2) == 0 else 5263440    # two dim greys, 40px stripes
            fill_rect(x, y, 40, 20, col)
            x <- x + 40
        y <- y + 20
    tt: i64 = t_ms if t_ms < 20000 else 20000
    sx: i64 = SM_X0.i64() + (SM_DX.i64() * tt) / 20000   # square moves right, independent of the scroll
    draw_square_at(sx.i32(), SG_H / 2 - SQ / 2, 15790320)

# contact-merge: two squares approach on the SAME lane. They touch/overlap for ~600ms around
# t=10s, then separate. CONTACT? must fire on the overlap (bboxes intersect) and the tracks must
# re-separate cleanly afterward — overlap is an INFERRED contact, not a certainty.
def scene_contact_merge(t_ms: i64) -> void:
    fill_bg(2105376)
    tt: i64 = t_ms if t_ms < 20000 else 20000
    # A comes from the left, B from the right; they meet near center at t~10s then reverse apart.
    # D is the approach depth (setup derives it from the seeded overlap; unseeded D=230, overlap 20px).
    half: i64 = tt if tt < 10000 else (20000 - tt)
    ax: i64 = 40 + (CM_D.i64() * half) / 10000        # 40 -> 40+D -> 40
    bx: i64 = 540 - (CM_D.i64() * half) / 10000       # 540 -> 540-D -> 540
    draw_square_at(ax.i32(), CM_Y, 15790320)
    draw_square_at(bx.i32(), CM_Y, 15790320)

# launch: A (upper lane, near-white) moves right and stops overlapping static B (lower lane,
# mid-grey) at t=TC; B departs rightward at 60 px/s from t=TB (TB=TC base; TB=TC-EL under
# early-launch — the causeless departure a continuity-prior would smooth over).
def scene_launch(t_ms: i64) -> void:
    fill_bg(2105376)
    ax_end: i32 = LA_BX - SQ + LA_OL
    tt: i64 = t_ms if t_ms < LA_TC.i64() else LA_TC.i64()
    ax: i64 = 40 + ((ax_end - 40).i64() * tt) / LA_TC.i64()
    tb: i64 = (LA_TC - LA_EL).i64() if VAR_EL == 1 else LA_TC.i64()
    bx: mutable i64 = LA_BX.i64()
    if t_ms > tb:
        bx <- LA_BX.i64() + ((t_ms - tb) * 60) / 1000
        bmax: i64 = (SG_W - SQ).i64()
        bx <- bmax if bx > bmax
    draw_square_at(ax.i32(), LA_Y - LA_OFF, 15790320)     # A near-white
    draw_square_at(bx.i32(), LA_Y + LA_OFF, 10066329)     # B mid-grey

def render_scene(scene_id: i32, t_ms: i64) -> void:
    if scene_id == 1:
        scene_counter_skip(t_ms)
    else:
        if scene_id == 2:
            scene_motion(t_ms)
        else:
            if scene_id == 3:
                scene_motion_trap(t_ms)
            else:
                if scene_id == 4:
                    scene_crossing_swap(t_ms)
                else:
                    if scene_id == 5:
                        scene_occlude_vanish(t_ms)
                    else:
                        if scene_id == 6:
                            scene_scroll_motion(t_ms)
                        else:
                            if scene_id == 7:
                                scene_contact_merge(t_ms)
                            else:
                                if scene_id == 8:
                                    scene_launch(t_ms)
                                else:
                                    scene_counter(t_ms)

# ---- seeded gold emission (V1.5): the generator annotates its own fixture ----------------------
#
# Only in seeded mode: truth.jsonl + probes.jsonl are computed from the SAME parameters that
# rendered the frames, in the exact record shapes score_memory.py / track_probe.py consume
# (probes carry op + span; golds follow the authored conventions: numeric counts, boolean yes/no,
# substring directions/zones). Unseeded fixtures keep using the authored gold in eval/scenarios/.

def jq(s: cstr) -> void:                              # "s"
    txt_byte(34)
    txt_str(s)
    txt_byte(34)

def jkey(k: cstr) -> void:                            # ,"k":   (leading comma; callers open with {"
    txt_byte(44)
    txt_byte(34)
    txt_str(k)
    txt_byte(34)
    txt_byte(58)

def gold_write(dir: cstr, name: cstr) -> void:
    build_named_path(&BATCH_PATH[0], &BATCH_TMP[0], dir, name)
    f: void&? = fopen(&BATCH_PATH[0], "wb".cast[u8&])
    if f is fp:
        _ = fwrite(&TXT[0], 1.usize(), txt_len.usize(), fp)
        _ = fclose(fp)

# one probes.jsonl line: {"id":..,"ask_t":s1,"kind":..,"span":[s0,s1],"op":..,"q":..,"gold":..,"match":..,"fact_t":..}
def emit_probe(id: cstr, kind: cstr, op: cstr, s0: i64, s1: i64, q: cstr, gold: cstr, mt: cstr, fact_t: i64) -> void:
    txt_byte(123)
    txt_byte(34)
    txt_str("id")
    txt_byte(34)
    txt_byte(58)
    jq(id)
    jkey("ask_t")
    txt_dec(s1)
    jkey("kind")
    jq(kind)
    jkey("span")
    txt_byte(91)
    txt_dec(s0)
    txt_byte(44)
    txt_dec(s1)
    txt_byte(93)
    jkey("op")
    jq(op)
    jkey("q")
    jq(q)
    jkey("gold")
    jq(gold)
    jkey("match")
    jq(mt)
    jkey("fact_t")
    txt_dec(fact_t)
    txt_byte(125)
    txt_byte(10)

# one counter digit probe (VLM-answered, no op): {"id":..,"ask_t":..,"kind":"perception","q":..,"gold":"<d>","match":"numeric","fact_t":..}
def emit_probe_dig(id: cstr, ask_t: i64, q: cstr, d: i32, fact_t: i64) -> void:
    txt_byte(123)
    txt_byte(34)
    txt_str("id")
    txt_byte(34)
    txt_byte(58)
    jq(id)
    jkey("ask_t")
    txt_dec(ask_t)
    jkey("kind")
    jq("perception")
    jkey("q")
    jq(q)
    jkey("gold")
    txt_byte(34)
    txt_dec(d.i64())
    txt_byte(34)
    jkey("match")
    jq("numeric")
    jkey("fact_t")
    txt_dec(fact_t)
    txt_byte(125)
    txt_byte(10)

# one relation probe (V1.3b): emit_probe plus an "arr_cx" field — A's centroid column (in the
# default 192-wide grid) at the moment it reaches B, so the op can locate the contact without
# CONTACT events or stable track ids.
def emit_probe_rel(id: cstr, s0: i64, s1: i64, q: cstr, gold: cstr, fact_t: i64, arr_cx: i64) -> void:
    txt_byte(123)
    txt_byte(34)
    txt_str("id")
    txt_byte(34)
    txt_byte(58)
    jq(id)
    jkey("ask_t")
    txt_dec(s1)
    jkey("kind")
    jq("relation")
    jkey("span")
    txt_byte(91)
    txt_dec(s0)
    txt_byte(44)
    txt_dec(s1)
    txt_byte(93)
    jkey("op")
    jq("move_before_arrival")
    jkey("arr_cx")
    txt_dec(arr_cx)
    jkey("q")
    jq(q)
    jkey("gold")
    jq(gold)
    jkey("match")
    jq("boolean")
    jkey("fact_t")
    txt_dec(fact_t)
    txt_byte(125)
    txt_byte(10)

# one truth.jsonl event line: {"type":"event","t":..,"id":..,"desc":..,"object":..}
def emit_event(t: i64, id: cstr, desc: cstr, obj: cstr) -> void:
    txt_byte(123)
    txt_byte(34)
    txt_str("type")
    txt_byte(34)
    txt_byte(58)
    jq("event")
    jkey("t")
    txt_dec(t)
    jkey("id")
    jq(id)
    jkey("desc")
    jq(desc)
    jkey("object")
    jq(obj)
    txt_byte(125)
    txt_byte(10)

# one truth.jsonl fact line: {"type":"fact","t0":..,"t1":..,"key":..,"value":..}
def emit_fact(t0: i64, t1: i64, key: cstr, value: cstr) -> void:
    txt_byte(123)
    txt_byte(34)
    txt_str("type")
    txt_byte(34)
    txt_byte(58)
    jq("fact")
    jkey("t0")
    txt_dec(t0)
    jkey("t1")
    txt_dec(t1)
    jkey("key")
    jq(key)
    jkey("value")
    jq(value)
    txt_byte(125)
    txt_byte(10)

def emit_gold(scene_id: i32, dir: cstr, dur: i64) -> void:
    return if SG_SEED < 0
    d_fwd: cstr = "left" if (scene_id == 2 and MO_MIR == 1) or (scene_id == 3 and MT_MIR == 1) else "right"
    zone: cstr = "left" if MO_MIR == 1 else "right"

    # ---- truth.jsonl ----
    txt_len <- 0
    if scene_id == 2:
        emit_event(MO_TB.i64(), "e1", "the square reverses direction at the screen edge", "o1") if VAR_NR == 0
        emit_fact(0, MO_TB.i64(), "direction", d_fwd)
    if scene_id == 3:
        if VAR_NV == 0:
            emit_event(MT_T0.i64(), "e1", "the square vanishes from view", "o1")
            emit_event(MT_T1.i64(), "e2", "the square reappears displaced backward", "o1")
            emit_fact(MT_T0.i64(), MT_T1.i64(), "visible", "no")
        if VAR_NR == 0:
            emit_event(MT_TR.i64(), "e3", "the square reverses direction in mid-field", "o1")
            emit_fact(MT_TR.i64(), MT_TR.i64(), "reversal_location", "middle")
    if scene_id == 4:
        emit_event(10000, "e1", "the two squares cross in the middle", "o1")
    if scene_id == 5:
        emit_event(OV_TBV.i64(), "e1", "the lower square vanishes for good", "o2")
        emit_fact((OV_BLX - SQ - 40).i64() * 20000 / 520, (OV_BLX + OV_BLW - 40).i64() * 20000 / 520, "upper_square_occluded", "yes")
    if scene_id == 6:
        emit_fact(SM_T0.i64(), (SM_T0 + SM_LEN).i64(), "background_scrolling", "yes")
    if scene_id == 7:
        emit_event(10000, "e1", "the two squares touch", "o1")
    if scene_id == 8:
        tb8: i64 = (LA_TC - LA_EL).i64() if VAR_EL == 1 else LA_TC.i64()
        emit_event(tb8, "e1", "the right square starts moving", "o2")
        emit_event(LA_TC.i64(), "e2", "the left square reaches the right square", "o1")
        emit_fact(tb8, tb8, "launch_before_contact", "yes" if VAR_EL == 1 else "no")
    gold_write(dir, "truth.jsonl")

    # ---- probes.jsonl ----
    txt_len <- 0
    if scene_id == 2:
        emit_probe("sm_count", "perception", "count", 0, dur, "How many moving objects are on the screen? Answer with a single number.", "1", "numeric", 0)
        emit_probe("sm_dir", "perception", "direction", 800, (MO_TB - 800).i64(), "Is the bright square moving to the left or to the right? Answer left or right.", d_fwd, "substring", 1000)
        emit_probe("sm_rev", "event", "reversal", 0, dur, "Does the square reverse its direction of motion at any point? Answer yes or no.", "no" if VAR_NR == 1 else "yes", "boolean", MO_TB.i64())
        emit_probe("sm_zone", "event", "reversal_zone", 0, dur, "Does the square change direction near the left edge, the middle, or the right edge? Answer left, middle, or right.", zone, "substring", MO_TB.i64()) if VAR_NR == 0
        emit_probe("sm_cont", "event", "continuous", 0, dur, "Is the square continuously visible for the whole clip? Answer yes or no.", "yes", "boolean", 0)
    if scene_id == 3:
        emit_probe("st_count", "perception", "count", 0, dur, "How many moving objects are on the screen? Answer with a single number.", "1", "numeric", 0)
        emit_probe("st_dir1", "perception", "direction", 500, (MT_T0 - 500).i64(), "Before it disappears, is the square moving left or right? Answer left or right.", d_fwd, "substring", 1000)
        emit_probe("st_gap", "event", "vanish_gap", (MT_T0 + 200).i64(), (MT_T1 - 100).i64(), "Does the square vanish completely at some point? Answer yes or no.", "no" if VAR_NV == 1 else "yes", "boolean", MT_T0.i64())
        emit_probe("st_cont", "event", "continuous", 0, dur, "Is the square continuously visible for the whole clip? Answer yes or no.", "yes" if VAR_NV == 1 else "no", "boolean", MT_T0.i64())
        emit_probe("st_dir2", "perception", "direction", (MT_T1 + 400).i64(), (MT_TR - 400).i64(), "After it reappears, is the square moving left or right? Answer left or right.", d_fwd, "substring", MT_T1.i64())
        emit_probe("st_rev", "event", "reversal", 0, dur, "Does the square reverse its direction of motion at any point? Answer yes or no.", "no" if VAR_NR == 1 and VAR_NV == 0 else "yes", "boolean", MT_TR.i64())
        emit_probe("st_zone", "event", "reversal_zone", 0, dur, "When the square changes direction, is it near the left edge, the middle, or the right edge? Answer left, middle, or right.", "middle", "substring", MT_TR.i64()) if VAR_NR == 0
    if scene_id == 4:
        emit_probe("sx_count", "perception", "count", 0, dur, "How many squares are on the screen? Answer with a single number.", "2", "numeric", 0)
        emit_probe("sx_two", "perception", "two_directions", 0, dur, "Are two squares moving in opposite horizontal directions? Answer yes or no.", "yes", "boolean", 0)
        emit_probe("sx_cont", "event", "continuous", 0, dur, "Is at least one object visible at every moment of the clip? Answer yes or no.", "yes", "boolean", 0)
    if scene_id == 5:
        emit_probe("so_count", "perception", "count", 0, dur, "How many distinct shapes are on the screen early in the clip? Answer with a single number.", "3", "numeric", 0)
        emit_probe("so_occ", "event", "occluded", 0, dur, "Does a square pass behind another object (become occluded) at any point? Answer yes or no.", "yes", "boolean", ((OV_BLX - SQ - 40).i64() * 20000) / 520)
    if scene_id == 6:
        emit_probe("ss_cont", "event", "continuous", 0, dur, "Is at least one object visible at every moment of the clip? Answer yes or no.", "yes", "boolean", 0)
    if scene_id == 7:
        # NOTE: no two_directions probe here — the op measures per-track-id net displacement, and
        # the merge/split churns ids, so it cannot answer a physical-identity question. The merge
        # identity exam belongs to V3.2 candidate sets, not to this op.
        emit_probe("sc_count", "perception", "count", 0, dur, "How many squares are on the screen? Answer with a single number.", "2", "numeric", 0)
        emit_probe("sc_cont", "event", "continuous", 0, dur, "Is at least one object visible at every moment of the clip? Answer yes or no.", "yes", "boolean", 0)
    if scene_id == 8:
        emit_probe("rl_count", "perception", "count", 0, dur, "How many squares are on the screen? Answer with a single number.", "2", "numeric", 0)
        # A's centroid column at arrival, in the default 192-wide grid (fixture width 192)
        arr8: i64 = ((LA_BX - SQ + LA_OL + SQ / 2).i64() * 192) / SG_W.i64()
        tb8p: i64 = (LA_TC - LA_EL).i64() if VAR_EL == 1 else LA_TC.i64()
        emit_probe_rel("rl_order", 0, dur, "Does the right square start moving before the left square reaches it? Answer yes or no.", "yes" if VAR_EL == 1 else "no", tb8p, arr8)
    if scene_id == 1:
        # digit probes at the two seeded trap positions (VLM-answered: no op)
        emit_probe_dig("sk_trap1", (SK_I * 2000 + 1000).i64(), "What single digit is shown now?", SEQ_SKIP[SK_I.usize()].i32(), (SK_I * 2000).i64())
        emit_probe_dig("sk_trap2", (SK_J * 2000 + 1000).i64(), "What single digit is shown now?", SEQ_SKIP[SK_J.usize()].i32(), (SK_J * 2000).i64())
        emit_probe("sk_mono", "event", "", 0, dur, "Did the digit increase by exactly 1 at every step (a clean 0..9 count)? Answer yes or no.", "no", "boolean", (SK_I * 2000).i64())
    if scene_id == 0:
        emit_probe("sn_mono", "event", "", 0, dur, "Did the digit increase by exactly 1 at every step (a clean 0..9 count)? Answer yes or no.", "yes", "boolean", 6000)
    gold_write(dir, "probes.jsonl")

# ---- driver ------------------------------------------------------------------------------------

def main(argc: int, argv: u8&&) -> int:
    requires argc >= 0
    # flags (--seed N, --final) may appear anywhere; positionals keep their historical order
    seed: mutable i64 = -1
    final: mutable i32 = 0
    p: mutable array[int, 6] = [0, 0, 0, 0, 0, 0]     # argv index of positional k (0 = absent)
    np: mutable i32 = 0
    ai: mutable int = 1
    while ai < argc:
        if sg_streq(argv[ai], "--seed"):
            seed <- atoi(argv[ai + 1]).i64() if ai + 1 < argc else -1
            ai <- ai + 2
        else:
            if sg_streq(argv[ai], "--final"):
                final <- 1
                ai <- ai + 1
            else:
                if sg_streq(argv[ai], "--phase"):
                    if ai + 1 < argc:
                        ph: i32 = atoi(argv[ai + 1]).i32()
                        PHASE_MS <- clamp_i32(ph, 0, 1900)
                    ai <- ai + 2
                else:
                    if sg_streq(argv[ai], "--variant"):
                        if ai + 1 < argc:
                            if sg_streq(argv[ai + 1], "no-vanish"):
                                VAR_NV <- 1
                            else:
                                if sg_streq(argv[ai + 1], "no-reverse"):
                                    VAR_NR <- 1
                                else:
                                    if sg_streq(argv[ai + 1], "early-launch"):
                                        VAR_EL <- 1
                                    else:
                                        _ = printf("scenegen: unknown variant (have: no-vanish, no-reverse, early-launch)\n".cast[u8&])
                                        return 2
                        ai <- ai + 2
                    else:
                        np <- np + 1
                        p[np.usize()] <- ai if np <= 5
                        ai <- ai + 1

    scene: u8& = argv[p[1.usize()]] if np >= 1 else "counter".cast[u8&]
    dir: cstr = argv[p[2.usize()]].cast[cstr] if np >= 2 else "/tmp/scenegen_out"
    out_w: i32 = clamp_i32(atoi(argv[p[3.usize()]]).i32() if np >= 3 else 192, 8, MAX_OUT_W)
    fps: i32 = clamp_i32(atoi(argv[p[4.usize()]]).i32() if np >= 4 else 10, 1, 60)
    dur_ms: i64 = at_least(atoi(argv[p[5.usize()]]).i32() if np >= 5 else 20000, 1000).i64()

    # reserved-seed guard (V1.5): seeds >= 1000 are the held-out final-scoring pool
    if seed >= RESERVED_SEED and final == 0:
        _ = printf("scenegen: seed is RESERVED for final scoring (>= 1000); pass --final to run it deliberately\n".cast[u8&])
        return 3

    scene_id: i32 = 0 if sg_streq(scene, "counter") else (1 if sg_streq(scene, "counter-skip") else (2 if sg_streq(scene, "motion") else (3 if sg_streq(scene, "motion-trap") else (4 if sg_streq(scene, "crossing-swap") else (5 if sg_streq(scene, "occlude-vanish") else (6 if sg_streq(scene, "scroll-motion") else (7 if sg_streq(scene, "contact-merge") else (8 if sg_streq(scene, "launch") else -1))))))))
    if scene_id < 0:
        _ = printf("scenegen: unknown scene (have: counter, counter-skip, motion, motion-trap, crossing-swap, occlude-vanish, scroll-motion, contact-merge, launch)\n".cast[u8&])
        return 2
    # variant compatibility: no-vanish is motion-trap only; no-reverse is motion / motion-trap
    if VAR_NV == 1 and scene_id != 3:
        _ = printf("scenegen: --variant no-vanish applies to motion-trap only\n".cast[u8&])
        return 2
    if VAR_NR == 1 and scene_id != 2 and scene_id != 3:
        _ = printf("scenegen: --variant no-reverse applies to motion / motion-trap only\n".cast[u8&])
        return 2
    if VAR_EL == 1 and scene_id != 8:
        _ = printf("scenegen: --variant early-launch applies to launch only\n".cast[u8&])
        return 2
    if VAR_NV + VAR_NR + VAR_EL > 1:
        _ = printf("scenegen: one variant at a time (a pair changes exactly one property)\n".cast[u8&])
        return 2
    setup_scene_params(scene_id, seed)

    _ = mkdir(dir.cast[u8&], 493)
    build_named_path(&LATEST_PATH[0], &LATEST_TMP[0], dir, "latest.txt")

    out_h0: i32 = clamp_i32(out_w * SG_H / SG_W, 8, 256)
    out_h: i32 = RING_STRIDE / out_w if out_w * out_h0 > RING_STRIDE else out_h0

    token_cap: i32 = 40000
    cap_bytes: i32 = token_cap * 4
    retain: i32 = 100000                  # eval keeps the whole run
    batch_frames: i32 = fps * 2 if fps * 2 <= MAX_BATCH_FRAMES else MAX_BATCH_FRAMES
    frame_interval_ms: i64 = (1000 / fps).i64()
    total: i32 = (dur_ms * fps.i64() / 1000).i32()

    archive_init(dir, 512)
    _ = printf("scenegen: rendering scene -> fixture (deterministic).\n".cast[u8&])
    batch: mutable i64 = 0
    f: mutable i32 = 0
    while f < total:
        i: mutable i32 = 0
        while i < batch_frames and f < total:
            t_ms: i64 = f.i64() * frame_interval_ms
            render_scene(scene_id, t_ms)
            archive_frame(&SCREEN_GRAB[0], SG_W, SG_H, t_ms)
            downscale_into(&SCREEN_GRAB[0], SG_W, SG_H, out_w, out_h, i * RING_STRIDE)
            write_frame_ppm(dir, batch, SG_W, SG_H) if i == 0
            FRAME_MS[i.usize()] <- t_ms
            i <- i + 1
            f <- f + 1
        _ = write_batch_dir(dir, batch, i, out_w, out_h, fps, cap_bytes, retain, token_cap, 1)
        batch <- batch + 1
    archive_stop()
    emit_gold(scene_id, dir, dur_ms)
    if seed >= 0:
        _ = printf("scenegen: seeded gold emitted (truth.jsonl + probes.jsonl).\n".cast[u8&])
    _ = printf("scenegen: done.\n".cast[u8&])
    return 0
